620,"Please configure a Deployment identified as api-server within ml. Rollback procedures for this deployment are documented in the runbook. Make sure it has naming the container app, scaled to 5 instances, with nginx:17 as the base image, and also with RollingUpdate as the strategy type.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""api-server""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""nginx:17""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""RollingUpdate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: ml
  labels:
    app: api-server
spec:
  replicas: 5
  selector:
    matchLabels:
      app: api-server
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: api-server
    spec:

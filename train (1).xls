159,"Please configure a Pod identified as circuit-breaker-pod within platform. Make sure it has needing 250m of CPU, naming the container worker, restarting on Always, while also based on the grafana/grafana:8 image, and with a memory request of 1Gi.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""grafana/grafana:8""}, {""path"": ""spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""250m""}, {""path"": ""spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""1Gi""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Always""}]","apiVersion: v1
kind: Pod

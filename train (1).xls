  name: worker
  namespace: development
  labels:
    app: worker
spec:
  replicas: 6
  selector:
    matchLabels:
      app: worker
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: worker
    spec:
      containers:
      - name: app
        image: elasticsearch:16
        ports:
        - containerPort: 9090
        imagePullPolicy: IfNotPresent",Deployment,6
303,"Configure the following Kubernetes resource: a Deployment with name model-trainer, deployed to development. Specifications include exposing container port 5000, running 4 copies, with its container called worker, additionally pulling python:21, and also employing Recreate for deployments.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""model-trainer""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""python:21""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""5000""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1

935,"Please configure a CronJob identified as cron-runner-cron within monitoring. Make sure it has running on schedule 30 2 * * *, in an active (unsuspended) state, additionally reserving 250m CPU resources.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cron-runner-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""30 2 * * *""}, {""path"": ""spec.suspend"", ""operator"": ""equals"", ""value"": ""False""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""250m""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: cron-runner-cron
  namespace: monitoring
spec:
  schedule: 30 2 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: cron
            image: nginx:8
            resources:
              requests:
                cpu: 250m
                memory: 64Mi
          restartPolicy: OnFailure
  concurrencyPolicy: Forbid
  suspend: false
  failedJobsHistoryLimit: 1",CronJob,6

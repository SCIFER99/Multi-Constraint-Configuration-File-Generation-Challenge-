            cpu: 50m
            memory: 2Gi",Deployment,8
561,"Configure the following Kubernetes resource: a Deployment with name payment-gateway, deployed to logging. Related services include the auth-proxy and rate-limiter deployments in the same namespace. Specifications include with a replica count of 4, while also reserving 250m CPU resources, pulling images with policy Always, with envoyproxy/envoy:3.9 as the base image, running in a container named main.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""envoyproxy/envoy:3.9""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.template.spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Always""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""250m""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: payment-gateway
  namespace: logging
  labels:
    app: payment-gateway
spec:
  replicas: 4
  selector:
    matchLabels:
      app: payment-gateway
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: payment-gateway
    spec:
      containers:
      - name: main
        image: envoyproxy/envoy:3.9
        ports:
        - containerPort: 8080
        resources:
          requests:
            cpu: 250m
            memory: 512Mi
        imagePullPolicy: Always
        env:
        - name: APP_NAME
          value: production",Deployment,8

        memory: 512Mi",Pod,7
734,"Please configure an Ingress identified as pdf-generator-ingress within infra. Make sure it has backed by service cache-proxy-svc, responding to requests for blog.example.com, on path /health, and also configured with pathType ImplementationSpecific, and serving on port 443.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""blog.example.com""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""443""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-svc""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""ImplementationSpecific""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/health""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: pdf-generator-ingress
  namespace: infra
spec:
  rules:
  - host: blog.example.com
    http:
      paths:
      - path: /health
        pathType: ImplementationSpecific
        backend:
          service:
            name: cache-proxy-svc
            port:
              number: 443
  ingressClassName: traefik",Ingress,8
735,"Please configure a Deployment identified as report-gen within production. The team responsible for this resource can be reached via the platform-ops Slack channel. Make sure it has naming the container main, additionally with 3 replicas, exposing the DATABASE_URL environment variable, and built from httpd:2.0.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""3""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""httpd:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""DATABASE_URL""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: report-gen
  namespace: production
  labels:
    app: report-gen
    env: production
spec:
  replicas: 3
  selector:
    matchLabels:
      app: report-gen
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: report-gen
        env: production
    spec:
      containers:
      - name: main
        image: httpd:2.0
        ports:
        - containerPort: 8500
        resources:
          requests:
            cpu: 200m
            memory: 128Mi
          limits:
            cpu: '2'
            memory: 128Mi
        imagePullPolicy: Never
        env:
        - name: DATABASE_URL
          value: production",Deployment,7
736,"Please configure a Deployment identified as file-uploader within monitoring. Make sure it has allocated 200m CPU, the container identified as main, running minio/minio:alpine, additionally limited to 50m CPU, having 4 replicated pods.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""minio/minio:alpine""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.template.spec.containers.0.resources.limits.cpu"", ""operator"": ""equals"", ""value"": ""50m""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""200m""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: file-uploader
  namespace: monitoring
  labels:
    app: file-uploader
    version: v1
spec:
  replicas: 4
  selector:
    matchLabels:
      app: file-uploader
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: file-uploader
        version: v1
    spec:
      containers:
      - name: main
        image: minio/minio:alpine
        ports:
        - containerPort: 27017
        resources:
          requests:
            cpu: 200m
            memory: 512Mi
          limits:
            cpu: 50m
            memory: 64Mi
        imagePullPolicy: Always",Deployment,8
737,The model-trainer-pod Pod operates in the logging namespace. It includes pulling grafana/grafana:slim. Ensure this configuration is reviewed by the security team before deployment. It is configured with running in a container named runner.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""model-trainer-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""grafana/grafana:slim""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}]","apiVersion: v1
kind: Pod
metadata:
  name: model-trainer-pod
  namespace: logging
  labels:
    app: model-trainer
spec:
  restartPolicy: OnFailure
  containers:
  - name: runner
    image: grafana/grafana:slim
    imagePullPolicy: Always",Pod,5
738,The backend-config ConfigMap operates in the data namespace.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: backend-config
  namespace: data
data:
  allowed_origins: https://example.com
  max_connections: '500'
  cache_ttl: '60'
  rate_limit: '500'
  app_port: '5000'
  retry_count: '3'",ConfigMap,3
739,"Configure the following Kubernetes resource: a Deployment with name api-server, deployed to monitoring. Specifications include scaled to 8 instances, using the Recreate deployment strategy, based on the envoyproxy/envoy:1.0 image, configuring the REDIS_URL variable, while also with its container called server.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""api-server""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""envoyproxy/envoy:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""REDIS_URL""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: monitoring
  labels:
    app: api-server
spec:
  replicas: 8
  selector:
    matchLabels:
      app: api-server
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: api-server
    spec:
      containers:
      - name: server
        image: envoyproxy/envoy:1.0

              number: 443",Ingress,4
1043,"Create a Pod called order-service-pod in the platform namespace. It should have pulling openjdk:stable, and reserving 1Gi of memory.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""order-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""openjdk:stable""}, {""path"": ""spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""1Gi""}]","apiVersion: v1

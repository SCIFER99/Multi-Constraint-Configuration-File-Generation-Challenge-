    protocol: UDP
  sessionAffinity: ClientIP",Service,5
88,"We need a CronJob named rate-limiter-cron in infra. The configuration requires pulling centos:16, and also allocated 50m CPU, with Never restart behavior, the container identified as worker, and executing on the 30 2 * * * cron schedule.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""30 2 * * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Never""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""50m""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:16""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: rate-limiter-cron
  namespace: infra
spec:
  schedule: 30 2 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: worker
            image: centos:16
            resources:
              requests:
                cpu: 50m
                memory: 1Gi
          restartPolicy: Never",CronJob,8

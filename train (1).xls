              number: 80
  tls:
  - hosts:
    - admin.example.com
    secretName: report-gen-tls",Ingress,8
533,"Configure the following Kubernetes resource: a Service with name gateway-svc, deployed to staging. Feature flags controlling this service are managed through LaunchDarkly. Ensure this configuration is reviewed by the security team before deployment. Specifications include set up as ClusterIP, with target port set to 9092, selecting pods labeled app=catalog-api, listening on port 8443.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""gateway-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""catalog-api""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""9092""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8443""}]","apiVersion: v1
kind: Service
metadata:
  name: gateway-svc
  namespace: staging
  labels:
    app: gateway
    team: platform
spec:
  type: ClusterIP
  selector:
    app: catalog-api
  ports:
  - port: 8443
    targetPort: 9092
    protocol: TCP",Service,7
534,"We need a Deployment named api-server in development. The team responsible for this resource can be reached via the platform-ops Slack channel. The data processed by this service is classified as PII and must comply with GDPR requirements. The configuration requires ruby:1.0 as the base image, naming the container app, with 5 replicas.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""api-server""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""ruby:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: development
  labels:
    app: api-server
    tier: queue
spec:
  replicas: 5
  selector:
    matchLabels:
      app: api-server
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: api-server
        tier: queue
    spec:
      containers:
      - name: app
        image: ruby:1.0
        ports:
        - containerPort: 9000",Deployment,6
535,"Configure a Pod called report-gen-pod in the logging namespace. This configuration supersedes the legacy setup that was decommissioned last quarter. It should have a memory request of 4Gi, declaring the PORT env var, with a restart policy of Never, using rabbitmq:2.0 as its container image, running under service account app-sa.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""rabbitmq:2.0""}, {""path"": ""spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""4Gi""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Never""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""PORT""}, {""path"": ""spec.serviceAccountName"", ""operator"": ""equals"", ""value"": ""app-sa""}]","apiVersion: v1
kind: Pod
metadata:
  name: report-gen-pod
  namespace: logging
  labels:
    app: report-gen
spec:
  restartPolicy: Never
  containers:
  - name: server
    image: rabbitmq:2.0
    ports:
    - containerPort: 27017
    resources:
      requests:
        cpu: 50m
        memory: 4Gi
    env:
    - name: PORT
      value: 'false'
    imagePullPolicy: IfNotPresent
  serviceAccountName: app-sa",Pod,8
536,The ssl-terminator Deployment operates in the logging namespace. It has configuring the REDIS_URL variable. It has exposing container port 3000. It requires a replica count of 10. It requires the container labeled app. It has built from httpd:1.1.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ssl-terminator""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""httpd:1.1""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""REDIS_URL""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""3000""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: ssl-terminator
  namespace: logging
  labels:
    app: ssl-terminator
spec:
  replicas: 10
  selector:
    matchLabels:
      app: ssl-terminator
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: ssl-terminator
    spec:
      containers:
      - name: app
        image: httpd:1.1
        ports:
        - containerPort: 3000
        env:
        - name: REDIS_URL
          value: '60'",Deployment,8
537,"Please configure a Service identified as image-processor-svc within development. The data processed by this service is classified as PII and must comply with GDPR requirements. Cost allocation for this resource falls under the platform-infrastructure budget category. Make sure it has TCP as the transport protocol, with service type ClusterIP, routing to pods where app is ssl-terminator, while also serving on port 9090, and tagged as tier=monitoring.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""image-processor-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""ssl-terminator""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""9090""}]","apiVersion: v1
kind: Service
metadata:
  name: image-processor-svc
  namespace: development
  labels:
    app: image-processor
    tier: monitoring
spec:
  type: ClusterIP
  selector:
    app: ssl-terminator
  ports:
  - port: 9090
    targetPort: 5432
    protocol: TCP",Service,8
538,"Configure the following Kubernetes resource: a Pod with name auth-service-pod, deployed to ml. Specifications include carrying label team: devops, tagged with app: auth-service, with the TIMEOUT environment variable, while also pulling postgres:stable.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""auth-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:stable""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""devops""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""auth-service""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""TIMEOUT""}]","apiVersion: v1
kind: Pod
metadata:
  name: auth-service-pod
  namespace: ml
  labels:
    app: auth-service
    team: devops
spec:
  restartPolicy: Never
  containers:
  - name: main
    image: postgres:stable
    env:
    - name: TIMEOUT
      value: 'false'",Pod,7
539,The email-sender Deployment operates in the data namespace. It requires whose container is called email-sender. It requires environment variable APP_NAME=true. It includes based on the postgres:slim image. It includes having 4 replicated pods.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:slim""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""email-sender""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""true""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: email-sender
  namespace: data
  labels:
    app: email-sender
    release: green
    tier: cache
spec:
  replicas: 4
  selector:
    matchLabels:
      app: email-sender
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: email-sender
        release: green
        tier: cache
    spec:
      containers:
      - name: email-sender
        image: postgres:slim
        ports:
        - containerPort: 4222
        resources:
          requests:
            cpu: 100m
            memory: 1Gi
          limits:
            cpu: 100m
            memory: 4Gi
        env:
        - name: APP_NAME
          value: 'true'",Deployment,7
540,The ml-inference-cron CronJob operates in the default namespace. It is configured with golang:1.1 as the base image. It includes the container identified as runner. It features set to fire at 0 6 * * *. It has a restart policy of OnFailure.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ml-inference-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 6 * * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""OnFailure""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""golang:1.1""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: ml-inference-cron
  namespace: default
  labels:
    env: staging
spec:
  schedule: 0 6 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: golang:1.1
            resources:
              requests:
                cpu: 200m
                memory: 128Mi
          restartPolicy: OnFailure
  successfulJobsHistoryLimit: 5",CronJob,7
541,"Please configure an Ingress identified as data-pipeline-ingress within production. Make sure it has routing requests to ws.example.com, while also managed by the istio ingress controller, and with TLS using the secret data-pipeline-tls.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""data-pipeline-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""ws.example.com""}, {""path"": ""spec.ingressClassName"", ""operator"": ""equals"", ""value"": ""istio""}, {""path"": ""spec.tls.0.secretName"", ""operator"": ""equals"", ""value"": ""data-pipeline-tls""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: data-pipeline-ingress
  namespace: production
spec:
  rules:
  - host: ws.example.com
    http:
      paths:
      - path: /admin
        pathType: Exact
        backend:
          service:

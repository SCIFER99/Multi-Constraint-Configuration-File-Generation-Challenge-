              number: 443
  tls:
  - hosts:
    - ws.example.com
    secretName: data-pipeline-tls
  ingressClassName: istio",Ingress,6
542,The cron-runner-pod Pod operates in the development namespace. It features running memcached:1.1. It includes environment variable API_KEY=debug.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cron-runner-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""memcached:1.1""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""debug""}]","apiVersion: v1
kind: Pod
metadata:
  name: cron-runner-pod
  namespace: development
  labels:
    app: cron-runner
spec:
  restartPolicy: OnFailure
  containers:
  - name: runner
    image: memcached:1.1
    ports:
    - containerPort: 3306
    env:
    - name: API_KEY
      value: debug",Pod,5
543,"We need a ConfigMap named report-gen-config in production. The configuration requires which includes a allowed_origins key, while also with a debug_mode entry present, where the debug_mode entry includes fal.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.debug_mode"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.allowed_origins"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.debug_mode"", ""operator"": ""contains"", ""value"": ""fal""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: report-gen-config
  namespace: production
data:
  allowed_origins: '*'
  debug_mode: 'false'
  rate_limit: '100'",ConfigMap,6
544,"Create a CronJob called web-app-cron in the platform namespace. Capacity planning documents suggest this workload will double by end of year. Rollback procedures for this deployment are documented in the runbook. It should have whose container is called runner, scheduled at 0 12 * * *.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""web-app-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 12 * * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: web-app-cron
  namespace: platform
  labels:
    team: infra
spec:
  schedule: 0 12 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: openjdk:2.0
          restartPolicy: Never
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 2",CronJob,5
545,"We need a Deployment named inventory-svc in default. The configuration requires running in a container named server, allocated 1Gi memory, additionally deployed via Recreate, additionally based on the logstash:8 image, and running 4 copies.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""inventory-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:8""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}, {""path"": ""spec.template.spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""1Gi""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: inventory-svc
  namespace: default
  labels:
    app: inventory-svc
    version: v1
spec:
  replicas: 4
  selector:
    matchLabels:
      app: inventory-svc
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: inventory-svc
        version: v1
    spec:
      containers:
      - name: server
        image: logstash:8
        ports:
        - containerPort: 15672
        resources:
          requests:
            cpu: 250m
            memory: 1Gi
          limits:
            cpu: '2'
            memory: 256Mi",Deployment,8
546,"Please configure a Service identified as backend-svc within infra. Make sure it has matching pods carrying app=report-gen, via TCP, and also listening on port 8443, while also configured as LoadBalancer, forwarding to target port 27017.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""report-gen""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8443""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""27017""}]","apiVersion: v1
kind: Service
metadata:
  name: backend-svc
  namespace: infra
spec:
  type: LoadBalancer
  selector:
    app: report-gen
  ports:
  - port: 8443
    targetPort: 27017
    protocol: TCP",Service,8
547,"Create a Pod called cache-proxy-pod in the data namespace. It should have pulling nats:1.2, and also the container identified as worker.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""nats:1.2""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}]","apiVersion: v1
kind: Pod
metadata:
  name: cache-proxy-pod
  namespace: data
  labels:
    app: cache-proxy
    tier: database
spec:
  restartPolicy: OnFailure

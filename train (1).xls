  name: log-aggregator-config
  namespace: platform
  labels:
    app: queue-worker
data:
  allowed_origins: '*'
  app_port: '3000'
  api_key_prefix: api-",ConfigMap,7
628,The dns-resolver-cron CronJob operates in the production namespace. It requires naming the container cron. It includes based on the elasticsearch:3.0 image. It is configured with restart mode set to OnFailure. It requires scheduled at 0 0 1 * *.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 0 1 * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""OnFailure""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""elasticsearch:3.0""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""cron""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: dns-resolver-cron
  namespace: production
  labels:
    env: production
spec:
  schedule: 0 0 1 * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: cron
            image: elasticsearch:3.0
            command:
            - /bin/sh
            - -c
            - echo hello
          restartPolicy: OnFailure
  concurrencyPolicy: Forbid
  suspend: false",CronJob,7
629,"Provision a CronJob called feature-store-cron in the ml namespace. This was previously hosted on AWS ECS before the Kubernetes migration. It should have executing on the 0 0 1 * * cron schedule, with a restart policy of Never, and also reserving 50m CPU resources, and carrying label app: pdf-generator.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""feature-store-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 0 1 * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""50m""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""pdf-generator""}, {""path"": ""spec.jobTemplate.spec.template.spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Never""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: feature-store-cron
  namespace: ml
  labels:
    app: pdf-generator
spec:
  schedule: 0 0 1 * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: worker
            image: nginx:8
            resources:
              requests:
                cpu: 50m
                memory: 4Gi
          restartPolicy: Never",CronJob,7
630,"Please configure a Deployment identified as frontend within default. Make sure it has pulling vault:1.1, and also with env var METRICS_PORT assigned to 3, and also running in a container named main, with a Recreate rollout strategy, maintaining 5 pods.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""vault:1.1""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""3""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: default
  labels:
    app: frontend
spec:
  replicas: 5
  selector:
    matchLabels:
      app: frontend
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: frontend
    spec:
      containers:
      - name: main
        image: vault:1.1
        ports:
        - containerPort: 9000
        env:
        - name: METRICS_PORT
          value: '3'",Deployment,8
631,"We need a Pod named notification-svc-pod in monitoring. The SLA for this service requires 99.95% uptime. The configuration requires the app label set to notification-svc, and also based on the golang:17 image, and reserving 4Gi of memory.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""notification-svc-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""golang:17""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""notification-svc""}, {""path"": ""spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""4Gi""}]","apiVersion: v1
kind: Pod
metadata:
  name: notification-svc-pod
  namespace: monitoring
  labels:
    app: notification-svc
    env: testing
spec:
  restartPolicy: Never
  containers:
  - name: runner
    image: golang:17
    ports:
    - containerPort: 1883
    resources:
      requests:
        cpu: '1'
        memory: 4Gi",Pod,6
632,The model-trainer-cron CronJob operates in the data namespace. It features executing on the */30 * * * * cron schedule.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""model-trainer-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""*/30 * * * *""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: model-trainer-cron
  namespace: data
spec:
  schedule: '*/30 * * * *'
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: postgres:1.1
            command:
            - /bin/sh
            - -c
            - date; echo done
          restartPolicy: Never
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 1",CronJob,4
633,"We need a ConfigMap named worker-config in ml. Feature flags controlling this service are managed through LaunchDarkly. Ensure this configuration is reviewed by the security team before deployment. The configuration requires where the cache_ttl field is 3600, containing log_level set to debug, additionally with a redis_host entry present.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""worker-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""data.cache_ttl"", ""operator"": ""equals"", ""value"": ""3600""}, {""path"": ""data.redis_host"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""debug""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: worker-config
  namespace: ml
  labels:
    app: image-processor
data:
  redis_host: redis://cache:6379/0
  log_level: debug
  app_env: production
  cache_ttl: '3600'",ConfigMap,6
634,"Provision a ConfigMap called email-sender-config in the production namespace. It should have having debug_mode match the substring tru, storing app_name with value search-engine, and also with the log_level value including err, and mapping log_level to error.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.log_level"", ""operator"": ""contains"", ""value"": ""err""}, {""path"": ""data.debug_mode"", ""operator"": ""contains"", ""value"": ""tru""}, {""path"": ""data.app_name"", ""operator"": ""equals"", ""value"": ""search-engine""}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""error""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: email-sender-config
  namespace: production
data:
  log_level: error
  max_connections: '50'
  api_key_prefix: sk-
  debug_mode: 'true'
  app_name: search-engine
  rate_limit: '100'",ConfigMap,7
635,The backend-ingress Ingress operates in the default namespace. It has bound to host shop.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""shop.example.com""}]","apiVersion: networking.k8s.io/v1

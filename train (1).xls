            cpu: 50m
            memory: 256Mi
        env:
        - name: METRICS_PORT
          value: 'true'",Deployment,8
1151,"Please configure a Service identified as email-sender-svc within data. Performance benchmarks show this configuration handles 500 concurrent connections comfortably. Make sure it has session affinity set to ClientIP, as a ClusterIP service, targeting pods with app=rate-limiter, and routing to backend port 9000.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.sessionAffinity"", ""operator"": ""equals"", ""value"": ""ClientIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""rate-limiter""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""9000""}]","apiVersion: v1
kind: Service
metadata:
  name: email-sender-svc
  namespace: data
  labels:
    app: email-sender
    team: backend
spec:
  type: ClusterIP
  selector:
    app: rate-limiter
  ports:
  - port: 9092
    targetPort: 9000
    protocol: TCP
  sessionAffinity: ClientIP",Service,7
1152,The log-aggregator Deployment operates in the development namespace. It includes scaled to 10 instances. It is configured with running in a container named main. It features running mongo:5.0.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""log-aggregator""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mongo:5.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: log-aggregator
  namespace: development
  labels:
    app: log-aggregator
spec:
  replicas: 10
  selector:
    matchLabels:
      app: log-aggregator
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: log-aggregator
    spec:
      containers:
      - name: main
        image: mongo:5.0
        ports:
        - containerPort: 11211
        resources:
          requests:
            cpu: 250m
            memory: 256Mi
        env:
        - name: TIMEOUT
          value: '8080'",Deployment,6
1153,The cache-proxy-svc Service operates in the ml namespace. It is configured with operating on TCP. The SLA for this service requires 99.95% uptime. This was previously hosted on AWS ECS before the Kubernetes migration. It is configured with configured as NodePort.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}]","apiVersion: v1
kind: Service
metadata:
  name: cache-proxy-svc
  namespace: ml
  labels:
    app: cache-proxy
    team: devops
spec:
  type: NodePort
  selector:
    app: config-server
  ports:
  - port: 9090
    targetPort: 8500
    protocol: TCP",Service,5
1154,"Set up a Deployment called file-uploader in the staging namespace. Expected traffic volume is approximately 10,000 requests per second during peak hours. It should have the container labeled app, running minio/minio:1.2, running 10 copies, while also annotated with version=v3.0.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""minio/minio:1.2""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""metadata.labels.version"", ""operator"": ""equals"", ""value"": ""v3.0""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: file-uploader
  namespace: staging
  labels:
    app: file-uploader
    tier: monitoring
    version: v3.0
spec:
  replicas: 10
  selector:
    matchLabels:
      app: file-uploader
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: file-uploader
        tier: monitoring
        version: v3.0
    spec:
      containers:
      - name: app
        image: minio/minio:1.2
        ports:
        - containerPort: 9092
        resources:
          requests:
            cpu: '1'
            memory: 64Mi
        imagePullPolicy: Always
        env:
        - name: PORT
          value: '60'",Deployment,7
1155,"Configure the following Kubernetes resource: a Service with name scheduler-svc, deployed to platform. Rollback procedures for this deployment are documented in the runbook. Specifications include with sticky sessions via ClientIP, while also via UDP, operating as a ClusterIP service, while also routing to backend port 5000, listening on port 8500.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""UDP""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8500""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""5000""}, {""path"": ""spec.sessionAffinity"", ""operator"": ""equals"", ""value"": ""ClientIP""}]","apiVersion: v1
kind: Service
metadata:
  name: scheduler-svc
  namespace: platform
spec:
  type: ClusterIP
  selector:
    app: gateway
  ports:
  - port: 8500
    targetPort: 5000
    protocol: UDP
  sessionAffinity: ClientIP",Service,8
1156,"Please configure an Ingress identified as scheduler-ingress within development. Make sure it has routing /static requests, while also with path matching set to Exact, serving status.example.com.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""status.example.com""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/static""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Exact""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: scheduler-ingress
  namespace: development
spec:
  rules:
  - host: status.example.com
    http:
      paths:
      - path: /static
        pathType: Exact
        backend:
          service:
            name: analytics-engine-svc
            port:
              number: 3000
  tls:
  - hosts:
    - status.example.com
    secretName: scheduler-tls",Ingress,6
1157,"Please configure an Ingress identified as dns-resolver-ingress within default. Make sure it has employing Prefix path matching, and responding to requests for example.com.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""example.com""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Prefix""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: dns-resolver-ingress
  namespace: default
  annotations:
    rewrite-target: 'true'
spec:
  rules:
  - host: example.com
    http:
      paths:
      - path: /uploads
        pathType: Prefix
        backend:
          service:
            name: event-bus-svc
            port:
              number: 80
  tls:
  - hosts:
    - example.com
    secretName: dns-resolver-tls",Ingress,5
1158,"Configure a Service called file-uploader-svc in the logging namespace. It should have configured as ClusterIP, while also configured with ClientIP affinity, and also labeled env=testing, listening on port 15672.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.sessionAffinity"", ""operator"": ""equals"", ""value"": ""ClientIP""}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""testing""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""15672""}]","apiVersion: v1
kind: Service
metadata:
  name: file-uploader-svc
  namespace: logging
  labels:
    app: file-uploader
    env: testing
spec:
  type: ClusterIP
  selector:
    app: web-app
  ports:
  - port: 15672
    targetPort: 1883
    protocol: TCP
  sessionAffinity: ClientIP",Service,7
1159,The batch-processor-cron CronJob operates in the platform namespace. It includes running on schedule */10 * * * *.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""*/10 * * * *""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: batch-processor-cron
  namespace: platform
spec:
  schedule: '*/10 * * * *'
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: mongo:8
            resources:
              requests:
                cpu: '1'
                memory: 128Mi
          restartPolicy: Never
  failedJobsHistoryLimit: 2",CronJob,4
1160,The frontend Deployment operates in the infra namespace. Feature flags controlling this service are managed through LaunchDarkly. It has having 2 replicated pods. It is configured with pulling centos:alpine. The on-call rotation for this service follows the standard PagerDuty schedule. It features whose container is called app. It features setting SECRET_KEY to production.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:alpine""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""production""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: infra
  labels:
    app: frontend
    env: staging
    team: backend
    tier: queue
spec:
  replicas: 2
  selector:
    matchLabels:
      app: frontend
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: frontend
        env: staging
        team: backend
        tier: queue
    spec:
      containers:
      - name: app
        image: centos:alpine
        ports:
        - containerPort: 4222
        env:
        - name: SECRET_KEY
          value: production",Deployment,7
1161,"We need a Service named worker-svc in default. The configuration requires port 27017 open, proxying to port 4222 on the backend, and of type NodePort.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""worker-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""4222""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""27017""}]","apiVersion: v1
kind: Service
metadata:
  name: worker-svc
  namespace: default
  labels:
    app: worker
    tier: queue
spec:
  type: NodePort
  selector:
    app: audit-logger
  ports:
  - port: 27017
    targetPort: 4222
    protocol: UDP",Service,6
1162,"Configure the following Kubernetes resource: a ConfigMap with name analytics-engine-config, deployed to ml. Specifications include mapping rate_limit to 100.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""analytics-engine-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""data.rate_limit"", ""operator"": ""equals"", ""value"": ""100""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: analytics-engine-config
  namespace: ml
  labels:
    env: staging
data:
  database_url: mongodb://mongo:27017/app
  app_name: auth-service
  feature_flags: enable_v2=true
  rate_limit: '100'",ConfigMap,4
1163,"Configure the following Kubernetes resource: a Pod with name backend-pod, deployed to infra. The SLA for this service requires 99.95% uptime. Integration tests for this component run in the CI pipeline on every merge to main. Specifications include with the app label set to backend, with httpd:14 as the base image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""httpd:14""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""backend""}]","apiVersion: v1
kind: Pod
metadata:
  name: backend-pod
  namespace: infra
  labels:
    app: backend
spec:
  restartPolicy: Never
  containers:
  - name: worker
    image: httpd:14
  serviceAccountName: admin",Pod,5
1164,"Please configure a ConfigMap identified as webhook-relay-config within logging. This was previously hosted on AWS ECS before the Kubernetes migration. Make sure it has a allowed_origins entry present, and where the timeout_seconds field is 10.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""webhook-relay-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""data.allowed_origins"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.timeout_seconds"", ""operator"": ""equals"", ""value"": ""10""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: webhook-relay-config
  namespace: logging
data:
  timeout_seconds: '10'
  allowed_origins: '*'
  log_level: warn",ConfigMap,5
1165,"Please configure a Pod identified as event-bus-pod within development. The team responsible for this resource can be reached via the platform-ops Slack channel. The data processed by this service is classified as PII and must comply with GDPR requirements. Make sure it has based on the centos:1.2 image, carrying label tier: cache, with the app label set to event-bus, using restart policy OnFailure, and with env var APP_NAME assigned to production.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""event-bus-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:1.2""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""event-bus""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""cache""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""OnFailure""}]","apiVersion: v1
kind: Pod
metadata:
  name: event-bus-pod
  namespace: development
  labels:
    app: event-bus
    tier: cache
spec:
  restartPolicy: OnFailure
  containers:
  - name: app
    image: centos:1.2
    resources:
      requests:
        cpu: 750m
        memory: 512Mi
    env:
    - name: APP_NAME
      value: production
  serviceAccountName: app-sa",Pod,8
1166,The service-mesh Deployment operates in the default namespace. It requires running 6 copies. It is configured with needing 128Mi memory. It includes naming the container worker. Performance benchmarks show this configuration handles 500 concurrent connections comfortably. The team responsible for this resource can be reached via the platform-ops Slack channel. It requires running grafana/grafana:1.0. It includes capping CPU at 1.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""service-mesh""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""6""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""grafana/grafana:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.resources.limits.cpu"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""128Mi""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: service-mesh
  namespace: default
  labels:
    app: service-mesh
spec:
  replicas: 6
  selector:
    matchLabels:
      app: service-mesh
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: service-mesh
    spec:
      containers:
      - name: worker
        image: grafana/grafana:1.0
        ports:
        - containerPort: 8443
        resources:
          requests:
            cpu: 50m
            memory: 128Mi
          limits:
            cpu: '1'
            memory: 128Mi",Deployment,8
1167,"We need a Service named search-engine-svc in staging. The configuration requires forwarding traffic to pods with app=config-server, accepting traffic on port 8080, operating as a LoadBalancer service.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""search-engine-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8080""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""config-server""}]","apiVersion: v1

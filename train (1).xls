  name: feature-store-svc
  namespace: platform
spec:
  type: ClusterIP
  selector:
    app: api-server
  ports:
  - port: 8200
    targetPort: 443
    protocol: UDP",Service,8
52,The scheduler Deployment operates in the monitoring namespace. It includes its container called scheduler. It is configured with running 1 copies. It is configured with mongo:14 as the base image. It has environment variable PORT=60.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mongo:14""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""scheduler""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""60""}]","apiVersion: apps/v1

        - containerPort: 3306",Deployment,6
851,"Create a Deployment called feature-store in the data namespace. It should have bearing the label tier=monitoring, using busybox:3.0 as its container image, with the container labeled feature-store, and running 10 copies.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""feature-store""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""busybox:3.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""feature-store""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""monitoring""}]","apiVersion: apps/v1
kind: Deployment

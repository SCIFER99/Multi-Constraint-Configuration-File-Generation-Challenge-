622,"Configure the following Kubernetes resource: a Deployment with name catalog-api, deployed to ml. Specifications include whose container is called main, additionally using httpd:3.1 as its container image, with a Recreate rollout strategy, and with a replica count of 10.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""catalog-api""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""httpd:3.1""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: catalog-api
  namespace: ml
  labels:
    app: catalog-api
spec:
  replicas: 10
  selector:
    matchLabels:
      app: catalog-api
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: catalog-api
    spec:
      containers:
      - name: main
        image: httpd:3.1
        ports:
        - containerPort: 9090
        resources:
          requests:
            cpu: '1'
            memory: 128Mi
        imagePullPolicy: Always",Deployment,7
623,"Configure the following Kubernetes resource: a ConfigMap with name stream-consumer-config, deployed to monitoring.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: stream-consumer-config
  namespace: monitoring
  labels:
    app: session-store
data:
  allowed_origins: https://app.example.com
  database_url: postgres://db:5432/app
  debug_mode: 'false'

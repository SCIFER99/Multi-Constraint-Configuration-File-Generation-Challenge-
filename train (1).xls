  serviceAccountName: default",Pod,4
1005,"Configure the following Kubernetes resource: a Deployment with name email-sender, deployed to production. Specifications include based on the logstash:2.0 image, naming the container server, and having 6 replicated pods.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""6""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: email-sender
  namespace: production
  labels:
    app: email-sender
spec:
  replicas: 6
  selector:
    matchLabels:
      app: email-sender
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: email-sender
    spec:
      containers:
      - name: server
        image: logstash:2.0
        ports:
        - containerPort: 8500
        resources:
          requests:
            cpu: 250m
            memory: 2Gi
        imagePullPolicy: IfNotPresent",Deployment,6
1006,"Deploy a Deployment called stream-consumer in the ml namespace. It should have vault:11 as the base image, exposing the WORKERS environment variable, with a replica count of 4, the container identified as server.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""vault:11""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""WORKERS""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: stream-consumer
  namespace: ml
  labels:
    app: stream-consumer
spec:
  replicas: 4
  selector:
    matchLabels:
      app: stream-consumer

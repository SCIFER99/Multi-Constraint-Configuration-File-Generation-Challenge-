    app: frontend
  ports:
  - port: 80
    targetPort: 8200
    protocol: TCP
    nodePort: 32291",Service,5
666,"Configure the following Kubernetes resource: a Pod with name payment-gateway-pod, deployed to platform. Specifications include restarting on Always, with the container labeled server, and with rabbitmq:20 as the base image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""rabbitmq:20""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Always""}]","apiVersion: v1
kind: Pod

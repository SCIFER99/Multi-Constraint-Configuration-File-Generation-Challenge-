            memory: 512Mi
          limits:
            cpu: 100m
            memory: 512Mi",Deployment,7
91,"Configure the following Kubernetes resource: a Deployment with name pdf-generator, deployed to staging. Rollback procedures for this deployment are documented in the runbook. Specifications include running ubuntu:latest, running 8 copies, and naming the container worker.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""ubuntu:latest""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}]","apiVersion: apps/v1

      requests:
        cpu: 200m
        memory: 1Gi
    env:
    - name: DEBUG
      value: info",Pod,4
378,"Configure the following Kubernetes resource: a Deployment with name batch-processor, deployed to monitoring. Specifications include naming the container batch-processor, using busybox:1.2 as its container image, employing RollingUpdate for deployments, with a replica count of 6.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""6""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""busybox:1.2""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""batch-processor""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""RollingUpdate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: batch-processor
  namespace: monitoring
  labels:
    app: batch-processor
    release: blue
spec:
  replicas: 6
  selector:
    matchLabels:
      app: batch-processor
  strategy:
    type: RollingUpdate

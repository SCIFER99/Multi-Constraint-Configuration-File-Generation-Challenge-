        ports:
        - containerPort: 9000
        resources:
          requests:
            cpu: '1'
            memory: 256Mi",Deployment,8
828,"Provision a ConfigMap called load-balancer-config in the staging namespace. It should have the app_name value including wor, storing app_name with value worker, with api_key_prefix configured as pk-.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""load-balancer-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""data.app_name"", ""operator"": ""contains"", ""value"": ""wor""}, {""path"": ""data.app_name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""data.api_key_prefix"", ""operator"": ""equals"", ""value"": ""pk-""}]","apiVersion: v1
kind: ConfigMap

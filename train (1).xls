              number: 3000
  ingressClassName: nginx",Ingress,5
579,The ml-inference-ingress Ingress operates in the monitoring namespace. This was previously hosted on AWS ECS before the Kubernetes migration. It has responding to requests for grafana.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ml-inference-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""grafana.example.com""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ml-inference-ingress
  namespace: monitoring
spec:
  rules:
  - host: grafana.example.com
    http:
      paths:

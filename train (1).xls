            cpu: 250m
            memory: 1Gi
        imagePullPolicy: Never",Deployment,7
852,"Configure the following Kubernetes resource: a Deployment with name frontend, deployed to ml. This service was originally implemented in the monolith and is now being extracted as a microservice. Specifications include with 5 replicas, with the container labeled worker, and also based on the elasticsearch:3.0 image, serving on container port 8500.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""elasticsearch:3.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""8500""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: ml
  labels:
    app: frontend
    env: production
spec:
  replicas: 5
  selector:
    matchLabels:
      app: frontend
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: frontend
        env: production
    spec:
      containers:
      - name: worker
        image: elasticsearch:3.0
        ports:
        - containerPort: 8500
        imagePullPolicy: Never
        env:
        - name: DEBUG
          value: 'true'",Deployment,7
853,"We need a Deployment named auth-service in development. The configuration requires running in a container named app, built from mongo:slim, while also scaled to 2 instances.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""auth-service""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mongo:slim""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: auth-service
  namespace: development
  labels:
    app: auth-service
    tier: frontend
    version: v3
spec:
  replicas: 2
  selector:
    matchLabels:
      app: auth-service

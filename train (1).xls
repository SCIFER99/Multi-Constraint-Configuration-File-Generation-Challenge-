    protocol: UDP",Service,6
1136,"Please configure a Deployment identified as notification-svc within logging. Make sure it has the container identified as main, with Recreate as the strategy type, and also scaled to 3 instances, and with memcached:2.0 as the base image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""notification-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""3""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""memcached:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: notification-svc
  namespace: logging
  labels:
    app: notification-svc
    release: green
spec:
  replicas: 3
  selector:
    matchLabels:
      app: notification-svc
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: notification-svc
        release: green
    spec:

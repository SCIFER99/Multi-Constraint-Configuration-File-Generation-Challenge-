            cpu: 750m
            memory: 256Mi
          limits:
            cpu: '1'
            memory: 128Mi",Deployment,6
559,"Configure the following Kubernetes resource: a Service with name payment-gateway-svc, deployed to ml. The data processed by this service is classified as PII and must comply with GDPR requirements. Specifications include operating as a LoadBalancer service, and carrying label tier: monitoring.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""monitoring""}]","apiVersion: v1

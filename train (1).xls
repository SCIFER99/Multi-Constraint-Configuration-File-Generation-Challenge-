594,"Provision a CronJob called backend-cron in the production namespace. It should have running on schedule */5 * * * *, and also with concurrency policy Replace, actively running (not suspended).","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""*/5 * * * *""}, {""path"": ""spec.suspend"", ""operator"": ""equals"", ""value"": ""False""}, {""path"": ""spec.concurrencyPolicy"", ""operator"": ""equals"", ""value"": ""Replace""}]","apiVersion: batch/v1
kind: CronJob

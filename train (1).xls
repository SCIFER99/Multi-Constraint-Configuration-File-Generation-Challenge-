1144,"Please configure a Pod identified as order-service-pod within logging. Make sure it has the team label set to backend, and also using debian:latest as its container image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""order-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""debian:latest""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""backend""}]","apiVersion: v1

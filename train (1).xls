              number: 443
  ingressClassName: nginx",Ingress,8
933,"We need a Deployment named inventory-svc in platform. Feature flags controlling this service are managed through LaunchDarkly. Ensure this configuration is reviewed by the security team before deployment. The configuration requires bearing the label tier=database, while also the container identified as worker, with 2 replicas, using postgres:2.0 as its container image, opening container port 8200.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""inventory-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""database""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""8200""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: inventory-svc
  namespace: platform
  labels:
    app: inventory-svc
    tier: database
spec:
  replicas: 2
  selector:
    matchLabels:
      app: inventory-svc
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: inventory-svc
        tier: database
    spec:

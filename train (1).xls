    app: service-mesh
  ports:
  - port: 9000
    targetPort: 80
    protocol: TCP",Service,5
665,"Configure the following Kubernetes resource: a Service with name catalog-api-svc, deployed to monitoring. Specifications include configured as NodePort, and accessible via port 80.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""catalog-api-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""80""}]","apiVersion: v1

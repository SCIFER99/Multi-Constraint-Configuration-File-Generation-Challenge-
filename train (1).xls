data:
  app_name: metrics-collector
  rate_limit: '100'
  database_url: postgres://db:5432/app
  timeout_seconds: '5'",ConfigMap,3
282,"Please configure a Pod identified as cdn-origin-pod within development. Make sure it has restart mode set to OnFailure, listening on port 8080, based on the elasticsearch:5.0 image, whose container is called app, labeled app=cdn-origin.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cdn-origin-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""elasticsearch:5.0""}, {""path"": ""spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""8080""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""OnFailure""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""cdn-origin""}]","apiVersion: v1

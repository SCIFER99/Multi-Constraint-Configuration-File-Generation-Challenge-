              number: 80",Ingress,5
312,"Please configure a Deployment identified as backend within staging. Make sure it has scaled to 4 instances, whose container is called worker, while also running busybox:1.0, and also needing 4Gi memory, deployed via Recreate.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""busybox:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""4Gi""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1
kind: Deployment

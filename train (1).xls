  name: cache-proxy-svc
  namespace: ml
  labels:
    app: cache-proxy
    tier: monitoring
spec:
  type: NodePort
  selector:
    app: metrics-collector
  ports:
  - port: 1883
    targetPort: 27017
    protocol: UDP
    nodePort: 30013",Service,6
997,The email-sender-cron CronJob operates in the default namespace. It is configured with running on schedule 0 */2 * * *. It is configured with tagged as app=analytics-engine.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 */2 * * *""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""analytics-engine""}]","apiVersion: batch/v1

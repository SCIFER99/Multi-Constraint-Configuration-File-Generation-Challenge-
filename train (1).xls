    secretName: backend-tls
  ingressClassName: istio",Ingress,7
500,"Deploy a Pod called search-engine-pod in the production namespace. It should have bearing the label tier=frontend, carrying the app=search-engine label, exposing the NODE_ENV environment variable, and also using restart policy OnFailure, running openjdk:1.1.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""search-engine-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""openjdk:1.1""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""OnFailure""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""search-engine""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""NODE_ENV""}]","apiVersion: v1
kind: Pod

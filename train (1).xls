          requests:
            cpu: 500m
            memory: 1Gi
        imagePullPolicy: Always
        env:
        - name: JWT_SECRET
          value: '8080'",Deployment,8
168,"We need a Pod named user-service-pod in monitoring. The configuration requires carrying the app=user-service label, using bitnami/kafka:16 as its container image, and using service account monitoring-sa.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""user-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""bitnami/kafka:16""}, {""path"": ""spec.serviceAccountName"", ""operator"": ""equals"", ""value"": ""monitoring-sa""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""user-service""}]","apiVersion: v1
kind: Pod
metadata:
  name: user-service-pod
  namespace: monitoring
  labels:
    app: user-service
spec:
  restartPolicy: OnFailure
  containers:
  - name: server
    image: bitnami/kafka:16
    imagePullPolicy: Never
  serviceAccountName: monitoring-sa",Pod,6
169,"Please configure a Pod identified as webhook-relay-pod within ml. Make sure it has naming the container worker, including SECRET_KEY in its environment, using alpine:11 as its container image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""webhook-relay-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""alpine:11""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""SECRET_KEY""}]","apiVersion: v1

558,"We need a Deployment named inventory-svc in development. The configuration requires the container labeled worker, additionally scaled to 5 instances, and built from postgres:alpine.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""inventory-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:alpine""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: inventory-svc
  namespace: development
  labels:
    app: inventory-svc
    version: v1.0
    tier: queue
spec:
  replicas: 5
  selector:
    matchLabels:
      app: inventory-svc
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: inventory-svc

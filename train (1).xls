            cpu: 50m
            memory: 256Mi",Deployment,7
596,"We need a Service named web-app-svc in production. The configuration requires operating on UDP, configured as ClusterIP, additionally with sticky sessions via ClientIP, and forwarding to target port 5000.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""web-app-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.sessionAffinity"", ""operator"": ""equals"", ""value"": ""ClientIP""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""5000""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""UDP""}]","apiVersion: v1
kind: Service

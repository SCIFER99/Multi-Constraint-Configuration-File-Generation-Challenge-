            port:
              number: 443",Ingress,6
1118,"Create a Deployment called scheduler in the platform namespace. It should have requesting 100m CPU, with 1 replicas, built from mongo:3.1, with its container called scheduler.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mongo:3.1""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""scheduler""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""100m""}]","apiVersion: apps/v1

  name: cache-proxy-config
  namespace: staging
data:
  app_port: '3000'
  app_env: production",ConfigMap,7
1179,"Provision a Deployment called ml-inference in the default namespace. It should have memcached:stable as the base image, running in a container named main, additionally having 6 replicated pods.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ml-inference""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""6""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""memcached:stable""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}]","apiVersion: apps/v1

  app_port: '8080'
  workers: '8'",ConfigMap,6
729,"Configure the following Kubernetes resource: an Ingress with name circuit-breaker-ingress, deployed to infra. Specifications include serving v2.api.example.com, configured with pathType Prefix, with port 3000 open.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""v2.api.example.com""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Prefix""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""3000""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: circuit-breaker-ingress
  namespace: infra
  annotations:
    description: /
  labels:
    env: production
spec:
  rules:
  - host: v2.api.example.com
    http:
      paths:
      - path: /api/v1
        pathType: Prefix
        backend:
          service:
            name: user-service-svc
            port:
              number: 3000",Ingress,6
730,Please configure a Pod identified as event-bus-pod within staging. Make sure it has rabbitmq:8 as the base image.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""event-bus-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""rabbitmq:8""}]","apiVersion: v1
kind: Pod
metadata:
  name: event-bus-pod
  namespace: staging
  labels:
    app: event-bus
    env: staging
spec:
  restartPolicy: Always

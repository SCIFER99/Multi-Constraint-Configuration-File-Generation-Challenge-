  name: cdn-origin
  namespace: infra
  labels:
    app: cdn-origin
    release: green
spec:
  replicas: 10
  selector:
    matchLabels:
      app: cdn-origin
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: cdn-origin
        release: green
    spec:
      containers:
      - name: app
        image: debian:11
        ports:
        - containerPort: 9092
        resources:
          requests:
            cpu: 250m
            memory: 128Mi
        imagePullPolicy: IfNotPresent",Deployment,7
822,"Set up a Pod called gateway-pod in the monitoring namespace. It should have the app label set to gateway, built from mysql:stable, exposing port 3306, additionally with the container labeled server.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""gateway-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mysql:stable""}, {""path"": ""spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""3306""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""gateway""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: v1
kind: Pod
metadata:
  name: gateway-pod
  namespace: monitoring
  labels:
    app: gateway
    env: development
spec:
  restartPolicy: Always
  containers:
  - name: server
    image: mysql:stable
    ports:
    - containerPort: 3306
    resources:
      requests:
        cpu: 50m
        memory: 2Gi
  serviceAccountName: default",Pod,7
823,"Create a ConfigMap called cache-proxy-config in the platform namespace. It should have where app_port contains 300, containing log_level set to info, carrying label team: ml.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""info""}, {""path"": ""data.app_port"", ""operator"": ""contains"", ""value"": ""300""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""ml""}]","apiVersion: v1
kind: ConfigMap

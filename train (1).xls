metadata:
  name: scheduler-ingress
  namespace: production
spec:
  rules:
  - host: cdn.example.com
    http:
      paths:
      - path: /api
        pathType: Prefix
        backend:
          service:
            name: user-service-svc
            port:
              number: 443",Ingress,8
93,"Deploy a Deployment called batch-processor in the infra namespace. Expected traffic volume is approximately 10,000 requests per second during peak hours. This service was originally implemented in the monolith and is now being extracted as a microservice. It should have pulling mysql:4.0, with 10 replicas, and whose container is called app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mysql:4.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1

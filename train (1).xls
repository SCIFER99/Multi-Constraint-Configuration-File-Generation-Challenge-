                cpu: 200m
                memory: 1Gi
          restartPolicy: OnFailure
  concurrencyPolicy: Replace
  failedJobsHistoryLimit: 2",CronJob,4
982,"We need a Pod named metrics-collector-pod in logging. The configuration requires where JWT_SECRET equals true, serving on port 4222, configured with Never pull behavior, and also running centos:1.2, and annotated with tier=frontend.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""metrics-collector-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:1.2""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""true""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Never""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""4222""}]","apiVersion: v1
kind: Pod
metadata:
  name: metrics-collector-pod
  namespace: logging
  labels:
    app: metrics-collector
    tier: frontend
spec:
  restartPolicy: Never
  containers:
  - name: app

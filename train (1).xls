68,"We need an Ingress named frontend-ingress in platform. The configuration requires TLS using the secret frontend-tls, additionally responding to requests for api.example.com.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""api.example.com""}, {""path"": ""spec.tls.0.secretName"", ""operator"": ""equals"", ""value"": ""frontend-tls""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: platform
spec:
  rules:
  - host: api.example.com
    http:
      paths:
      - path: /metrics
        pathType: Prefix
        backend:
          service:
            name: pdf-generator-svc
            port:
              number: 8080
  tls:
  - hosts:
    - api.example.com
    secretName: frontend-tls
  ingressClassName: haproxy",Ingress,5

      - name: app
        image: busybox:16
        ports:
        - containerPort: 443",Deployment,7
75,"Configure the following Kubernetes resource: a ConfigMap with name scheduler-config, deployed to production. Specifications include where the api_key_prefix field is sk-, having the feature_flags field, and having the api_key_prefix field.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.api_key_prefix"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.feature_flags"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.api_key_prefix"", ""operator"": ""equals"", ""value"": ""sk-""}]","apiVersion: v1

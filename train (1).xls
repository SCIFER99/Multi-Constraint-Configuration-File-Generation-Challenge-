data:
  database_url: mongodb://mongo:27017/app
  timeout_seconds: '60'",ConfigMap,5
876,The load-balancer-cron CronJob operates in the development namespace. It features running on schedule 0 0 * * *. It includes retaining 1 successful job records. It is configured with annotated with app=data-pipeline. It requires pulling rabbitmq:3.1.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""load-balancer-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 0 * * *""}, {""path"": ""spec.successfulJobsHistoryLimit"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""rabbitmq:3.1""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""data-pipeline""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: load-balancer-cron
  namespace: development
  labels:
    app: data-pipeline
spec:
  schedule: 0 0 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: rabbitmq:3.1
          restartPolicy: OnFailure
  suspend: false
  successfulJobsHistoryLimit: 1",CronJob,7
877,Please configure a CronJob identified as audit-logger-cron within logging. Make sure it has set to fire at 30 2 * * *.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""audit-logger-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""30 2 * * *""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: audit-logger-cron
  namespace: logging
  labels:
    env: development
spec:
  schedule: 30 2 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: task
            image: ubuntu:8
          restartPolicy: Never
  suspend: false
  failedJobsHistoryLimit: 2",CronJob,4
878,"Spin up a ConfigMap called dns-resolver-config in the infra namespace. Ensure this configuration is reviewed by the security team before deployment. It should have where database_url contains mys, having the app_env field, while also where the api_key_prefix field is sk-, mapping retry_count to 5, and mapping app_name to gateway.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""data.database_url"", ""operator"": ""contains"", ""value"": ""mys""}, {""path"": ""data.api_key_prefix"", ""operator"": ""equals"", ""value"": ""sk-""}, {""path"": ""data.app_env"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.retry_count"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""data.app_name"", ""operator"": ""equals"", ""value"": ""gateway""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: dns-resolver-config
  namespace: infra
data:
  app_env: staging
  api_key_prefix: sk-
  retry_count: '5'
  database_url: mysql://db:3306/app
  app_name: gateway
  allowed_origins: https://app.example.com",ConfigMap,8
879,The ml-inference-ingress Ingress operates in the infra namespace. It requires exposing port 443. It requires routing /admin requests. This component is part of the Q3 platform migration project. It has routing requests to grafana.example.com. This service was originally implemented in the monolith and is now being extracted as a microservice. It is configured with a Exact pathType.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ml-inference-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""grafana.example.com""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""443""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Exact""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/admin""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ml-inference-ingress
  namespace: infra
  labels:
    app: session-store
spec:
  rules:
  - host: grafana.example.com
    http:
      paths:
      - path: /admin
        pathType: Exact
        backend:
          service:
            name: notification-svc-svc
            port:
              number: 443
  tls:
  - hosts:
    - grafana.example.com
    secretName: ml-inference-tls",Ingress,7
880,"We need a Deployment named pdf-generator in data. The configuration requires exposing container port 1883, with the version label set to v2, running in a container named main, running 1 copies, built from minio/minio:11.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""minio/minio:11""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""1883""}, {""path"": ""metadata.labels.version"", ""operator"": ""equals"", ""value"": ""v2""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: pdf-generator
  namespace: data
  labels:
    app: pdf-generator
    tier: backend
    version: v2
    env: testing
spec:
  replicas: 1
  selector:
    matchLabels:
      app: pdf-generator
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: pdf-generator
        tier: backend
        version: v2
        env: testing
    spec:
      containers:
      - name: main
        image: minio/minio:11
        ports:
        - containerPort: 1883
        resources:
          requests:
            cpu: '1'
            memory: 1Gi",Deployment,8
881,"We need a Deployment named inventory-svc in default. The configuration requires its container called inventory-svc, running 4 copies, and pulling logstash:21.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""inventory-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:21""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""inventory-svc""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: inventory-svc
  namespace: default
  labels:
    app: inventory-svc
    release: green
    tier: cache
spec:
  replicas: 4
  selector:
    matchLabels:
      app: inventory-svc
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: inventory-svc
        release: green
        tier: cache
    spec:
      containers:
      - name: inventory-svc
        image: logstash:21
        ports:
        - containerPort: 8200
        resources:
          requests:
            cpu: '2'
            memory: 1Gi
          limits:
            cpu: 200m
            memory: 1Gi",Deployment,6
882,"Please configure a ConfigMap identified as event-bus-config within default. Ensure this configuration is reviewed by the security team before deployment. Make sure it has which includes a redis_host key, where the redis_host field is redis://cache:6379/0, while also bearing the label app=feature-store.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""event-bus-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""data.redis_host"", ""operator"": ""equals"", ""value"": ""redis://cache:6379/0""}, {""path"": ""data.redis_host"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""feature-store""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: event-bus-config
  namespace: default
  labels:
    app: feature-store
data:
  cache_ttl: '60'
  redis_host: redis://cache:6379/0
  workers: '1'",ConfigMap,6
883,"Configure the following Kubernetes resource: a Pod with name payment-gateway-pod, deployed to monitoring. Specifications include environment variable DATABASE_URL=8080, based on the centos:16 image, and also tagged with app: payment-gateway, using Always image pull policy, and the container identified as main.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:16""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""payment-gateway""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Always""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""8080""}]","apiVersion: v1
kind: Pod
metadata:
  name: payment-gateway-pod
  namespace: monitoring
  labels:
    app: payment-gateway
    env: development
spec:
  restartPolicy: OnFailure
  containers:
  - name: main
    image: centos:16
    env:
    - name: DATABASE_URL
      value: '8080'
    imagePullPolicy: Always",Pod,8
884,"We need an Ingress named frontend-ingress in data. The configuration requires directing traffic for the host docs.example.com, and also annotated with rewrite-target set to Ingress.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""docs.example.com""}, {""path"": ""metadata.annotations.rewrite-target"", ""operator"": ""equals"", ""value"": ""Ingress for frontend-ingress""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: data
  annotations:
    rewrite-target: Ingress for frontend-ingress
  labels:
    env: staging
spec:
  rules:
  - host: docs.example.com
    http:
      paths:
      - path: /metrics
        pathType: Exact
        backend:
          service:
            name: feature-store-svc
            port:
              number: 5000
  tls:
  - hosts:
    - docs.example.com
    secretName: frontend-tls
  ingressClassName: traefik",Ingress,5
885,"We need a Deployment named payment-gateway in logging. Documentation for this component is maintained in the team wiki under infrastructure/configs. Integration tests for this component run in the CI pipeline on every merge to main. The configuration requires maintaining 6 pods, with the container labeled app, and built from memcached:1.1.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""6""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""memcached:1.1""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: payment-gateway
  namespace: logging
  labels:
    app: payment-gateway
    release: stable
    version: v3.0
spec:
  replicas: 6
  selector:
    matchLabels:
      app: payment-gateway
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: payment-gateway
        release: stable
        version: v3.0
    spec:
      containers:
      - name: app
        image: memcached:1.1
        ports:
        - containerPort: 1883",Deployment,6
886,The order-service-cron CronJob operates in the staging namespace. It features the cron schedule 30 2 * * *. It is configured with whose container is called runner. It includes tagged as env=testing. It requires successfulJobsHistoryLimit set to 1.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""order-service-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""30 2 * * *""}, {""path"": ""spec.successfulJobsHistoryLimit"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""testing""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: order-service-cron
  namespace: staging
  labels:
    env: testing
spec:
  schedule: 30 2 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: runner
            image: debian:alpine
            command:
            - /bin/sh
            - -c
            - echo hello
          restartPolicy: Never
  successfulJobsHistoryLimit: 1",CronJob,7
887,"Spin up a ConfigMap called batch-processor-config in the production namespace. Integration tests for this component run in the CI pipeline on every merge to main. This was previously hosted on AWS ECS before the Kubernetes migration. It should have where the log_level entry includes err, additionally having the api_key_prefix field, mapping app_env to development, with the app_env value including dev, mapping log_level to error.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.app_env"", ""operator"": ""contains"", ""value"": ""dev""}, {""path"": ""data.api_key_prefix"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.app_env"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""error""}, {""path"": ""data.log_level"", ""operator"": ""contains"", ""value"": ""err""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: batch-processor-config
  namespace: production
  labels:
    team: ml
data:
  rate_limit: '5000'
  api_key_prefix: api-
  log_level: error
  app_env: development",ConfigMap,8
888,The cron-runner Deployment operates in the ml namespace. It has scaled to 3 instances. It features naming the container app. It includes node:1.0 as the base image.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cron-runner""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""3""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""node:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: cron-runner
  namespace: ml
  labels:
    app: cron-runner
    tier: queue
    release: green
    version: v2
spec:
  replicas: 3
  selector:
    matchLabels:
      app: cron-runner
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: cron-runner
        tier: queue
        release: green
        version: v2
    spec:
      containers:
      - name: app
        image: node:1.0
        ports:
        - containerPort: 8500
        env:
        - name: CACHE_TTL
          value: '8080'",Deployment,6
889,"Configure the following Kubernetes resource: a Service with name report-gen-svc, deployed to development. Specifications include operating as a NodePort service, routing to backend port 9092, additionally selecting pods labeled app=backend, and communicating over TCP.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""backend""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""9092""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}]","apiVersion: v1
kind: Service
metadata:
  name: report-gen-svc
  namespace: development
  labels:
    app: report-gen
    team: backend
spec:
  type: NodePort
  selector:
    app: backend
  ports:
  - port: 15672
    targetPort: 9092
    protocol: TCP
  sessionAffinity: ClientIP",Service,7
890,"Spin up a Service called user-service-svc in the platform namespace. It should have configured as LoadBalancer, and also carrying label env: production, forwarding to target port 3000.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""user-service-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""3000""}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""production""}]","apiVersion: v1
kind: Service
metadata:
  name: user-service-svc
  namespace: platform
  labels:
    app: user-service
    env: production
spec:
  type: LoadBalancer
  selector:
    app: inventory-svc
  ports:
  - port: 5000
    targetPort: 3000
    protocol: TCP",Service,6
891,"Configure the following Kubernetes resource: a Deployment with name queue-worker, deployed to infra. The data processed by this service is classified as PII and must comply with GDPR requirements. Related services include the auth-proxy and rate-limiter deployments in the same namespace. Specifications include with the container labeled app, based on the postgres:11 image, additionally bearing the label tier=monitoring, and also scaled to 2 instances.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""queue-worker""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:11""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""monitoring""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: queue-worker
  namespace: infra
  labels:
    app: queue-worker
    tier: monitoring
spec:
  replicas: 2
  selector:
    matchLabels:
      app: queue-worker
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: queue-worker
        tier: monitoring
    spec:
      containers:
      - name: app
        image: postgres:11
        ports:
        - containerPort: 80
        resources:
          requests:
            cpu: 750m
            memory: 128Mi",Deployment,7
892,"Create a ConfigMap called image-processor-config in the development namespace. It should have which includes a workers key, where the database_url field is mysql://db:3306/app, where the api_key_prefix field is sk-, additionally having log_level=info in its data, and with timeout_seconds configured as 60.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""image-processor-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""data.api_key_prefix"", ""operator"": ""equals"", ""value"": ""sk-""}, {""path"": ""data.workers"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.database_url"", ""operator"": ""equals"", ""value"": ""mysql://db:3306/app""}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""info""}, {""path"": ""data.timeout_seconds"", ""operator"": ""equals"", ""value"": ""60""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: image-processor-config
  namespace: development
data:
  workers: '2'
  log_level: info
  retry_count: '3'
  database_url: mysql://db:3306/app
  api_key_prefix: sk-
  timeout_seconds: '60'",ConfigMap,8
893,"Configure a Pod called feature-store-pod in the staging namespace. This configuration supersedes the legacy setup that was decommissioned last quarter. This was previously hosted on AWS ECS before the Kubernetes migration. It should have Always restart behavior, and with consul:17 as the base image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""feature-store-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""consul:17""}, {""path"": ""spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Always""}]","apiVersion: v1
kind: Pod
metadata:
  name: feature-store-pod
  namespace: staging
  labels:
    app: feature-store
    env: development
spec:
  restartPolicy: Always
  containers:
  - name: main
    image: consul:17
    imagePullPolicy: Never",Pod,5
894,"Configure the following Kubernetes resource: a Service with name service-mesh-svc, deployed to logging. Specifications include as a NodePort service, while also operating on TCP, and exposed externally on port 31124.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""service-mesh-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.ports.0.nodePort"", ""operator"": ""equals"", ""value"": ""31124""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}]","apiVersion: v1
kind: Service
metadata:
  name: service-mesh-svc
  namespace: logging
  labels:
    app: service-mesh
    tier: database
spec:
  type: NodePort
  selector:
    app: audit-logger
  ports:
  - port: 5432
    targetPort: 5432
    protocol: TCP
    nodePort: 31124
  sessionAffinity: ClientIP",Service,6
895,"Configure the following Kubernetes resource: a Deployment with name frontend, deployed to monitoring. Specifications include having 4 replicated pods, annotated with team=devops, based on the bitnami/kafka:2.0 image, the container identified as app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""bitnami/kafka:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""devops""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: monitoring
  labels:
    app: frontend
    team: devops
    env: development
spec:
  replicas: 4
  selector:
    matchLabels:
      app: frontend
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: frontend
        team: devops
        env: development
    spec:

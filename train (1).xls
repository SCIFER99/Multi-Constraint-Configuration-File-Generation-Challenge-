932,"We need an Ingress named dns-resolver-ingress in default. The configuration requires routed through the nginx ingress class, while also handling the /api/v2 endpoint, and also serving dashboard.example.com, with port 443 open, and directing traffic to service report-gen-svc.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""dashboard.example.com""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.name"", ""operator"": ""equals"", ""value"": ""report-gen-svc""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/api/v2""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""443""}, {""path"": ""spec.ingressClassName"", ""operator"": ""equals"", ""value"": ""nginx""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: dns-resolver-ingress
  namespace: default
spec:

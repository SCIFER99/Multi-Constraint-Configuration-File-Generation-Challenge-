  name: load-balancer-config
  namespace: logging
data:
  app_env: development
  timeout_seconds: '5'
  database_url: mongodb://mongo:27017/app
  rate_limit: '5000'",ConfigMap,4
875,The proxy-server-config ConfigMap operates in the logging namespace. It requires a timeout_seconds entry present. It includes database_url containing the text mon.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""proxy-server-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""data.timeout_seconds"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.database_url"", ""operator"": ""contains"", ""value"": ""mon""}]","apiVersion: v1

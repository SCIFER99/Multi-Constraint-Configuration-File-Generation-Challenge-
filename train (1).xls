  name: worker
  namespace: data
  labels:
    app: worker
    env: production
    version: v2.0
spec:
  replicas: 3
  selector:
    matchLabels:
      app: worker
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: worker
        env: production

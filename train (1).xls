  debug_mode: 'true'",ConfigMap,4
1066,"Configure the following Kubernetes resource: a Deployment with name circuit-breaker, deployed to default. Cost allocation for this resource falls under the platform-infrastructure budget category. Specifications include having 1 replicated pods, running in a container named circuit-breaker, pulling mysql:3.0, and configured with IfNotPresent pull behavior.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mysql:3.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker""}, {""path"": ""spec.template.spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""IfNotPresent""}]","apiVersion: apps/v1

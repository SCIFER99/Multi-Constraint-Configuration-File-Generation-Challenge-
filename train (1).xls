1140,"We need a Deployment named frontend in staging. The configuration requires naming the container frontend, using vault:20 as its container image, having 8 replicated pods, bearing the label release=green, and using the RollingUpdate deployment strategy.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""vault:20""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""metadata.labels.release"", ""operator"": ""equals"", ""value"": ""green""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""RollingUpdate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
  namespace: staging
  labels:
    app: frontend
    team: devops
    release: green
spec:
  replicas: 8
  selector:
    matchLabels:
      app: frontend
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: frontend
        team: devops
        release: green
    spec:
      containers:
      - name: frontend
        image: vault:20
        ports:
        - containerPort: 5000
        resources:
          requests:
            cpu: 100m
            memory: 1Gi
        imagePullPolicy: Always",Deployment,8
1141,Set up a ConfigMap called report-gen-config in the logging namespace.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}]","apiVersion: v1

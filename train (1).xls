        ports:
        - containerPort: 1883
        resources:
          requests:
            cpu: 50m
            memory: 64Mi
          limits:
            cpu: 1000m
            memory: 2Gi
        imagePullPolicy: IfNotPresent",Deployment,7
621,"Please configure a Pod identified as pdf-generator-pod within logging. Make sure it has built from envoyproxy/envoy:3.9, carrying label env: staging.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""envoyproxy/envoy:3.9""}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""staging""}]","apiVersion: v1

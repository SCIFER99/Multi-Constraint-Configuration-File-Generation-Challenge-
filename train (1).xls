        backend:
          service:
            name: feature-store-svc
            port:
              number: 5000",Ingress,4
499,"Configure the following Kubernetes resource: an Ingress with name backend-ingress, deployed to logging. Specifications include routed through the istio ingress class, using pathType ImplementationSpecific, serving api.example.com, and routing to backend service image-processor-svc.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""api.example.com""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""ImplementationSpecific""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.name"", ""operator"": ""equals"", ""value"": ""image-processor-svc""}, {""path"": ""spec.ingressClassName"", ""operator"": ""equals"", ""value"": ""istio""}]","apiVersion: networking.k8s.io/v1

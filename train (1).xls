              number: 5000
  ingressClassName: traefik",Ingress,4
123,"We need a Deployment named dns-resolver in platform. The configuration requires running in a container named dns-resolver, having 8 replicated pods, and built from bitnami/kafka:slim.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""bitnami/kafka:slim""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""dns-resolver""}]","apiVersion: apps/v1
kind: Deployment

1094,"Please configure a Deployment identified as backend within logging. Make sure it has running in a container named backend, having 1 replicated pods, and also pulling kibana:latest.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""backend""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""kibana:latest""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""backend""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: logging
  labels:
    app: backend
    env: testing
spec:

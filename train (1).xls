        - containerPort: 27017
        imagePullPolicy: Always
        env:
        - name: REDIS_URL
          value: info",Deployment,8
740,"Please configure a Deployment identified as catalog-api within default. Make sure it has built from grafana/grafana:3.9, maintaining 10 pods, with the container labeled server.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""catalog-api""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""grafana/grafana:3.9""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: catalog-api
  namespace: default
  labels:
    app: catalog-api
spec:
  replicas: 10
  selector:
    matchLabels:
      app: catalog-api
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: catalog-api
    spec:

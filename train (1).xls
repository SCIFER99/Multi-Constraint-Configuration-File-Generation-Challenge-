  name: cdn-origin-config
  namespace: development
  labels:
    env: testing
data:
  rate_limit: '1000'
  timeout_seconds: '10'
  retry_count: '3'",ConfigMap,6
107,"Deploy a Deployment called service-mesh in the production namespace. It should have 1 replicas, using httpd:16 as its container image, with its container called app, while also with APP_NAME configured as 8080.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""service-mesh""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""httpd:16""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""8080""}]","apiVersion: apps/v1
kind: Deployment

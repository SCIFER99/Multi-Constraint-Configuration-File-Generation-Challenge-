                cpu: '2'
                memory: 512Mi
          restartPolicy: OnFailure
  concurrencyPolicy: Allow
  successfulJobsHistoryLimit: 5",CronJob,7
116,"Create a Deployment called scheduler in the data namespace. It should have a replica count of 1, and also based on the prom/prometheus:1.2 image, and with its container called server.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""scheduler""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""prom/prometheus:1.2""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: scheduler
  namespace: data
  labels:
    app: scheduler
spec:
  replicas: 1
  selector:
    matchLabels:
      app: scheduler
  strategy:
    type: RollingUpdate
  template:

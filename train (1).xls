  name: analytics-engine-svc
  namespace: default
  labels:
    app: analytics-engine
    team: ml
spec:
  type: NodePort
  selector:
    app: ssl-terminator
  ports:
  - port: 8200
    targetPort: 9092
    protocol: TCP
    nodePort: 32637",Service,7
37,"We need an Ingress named rate-limiter-ingress in development. The configuration requires ingress class traefik, serving cdn.example.com, accessible via port 443, using pathType ImplementationSpecific, capturing requests to /ws.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""cdn.example.com""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/ws""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""443""}, {""path"": ""spec.ingressClassName"", ""operator"": ""equals"", ""value"": ""traefik""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""ImplementationSpecific""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: rate-limiter-ingress
  namespace: development
  labels:
    app: load-balancer
spec:
  rules:
  - host: cdn.example.com
    http:
      paths:
      - path: /ws
        pathType: ImplementationSpecific
        backend:
          service:
            name: stream-consumer-svc
            port:
              number: 443
  ingressClassName: traefik",Ingress,8
38,"Configure the following Kubernetes resource: a Pod with name user-service-pod, deployed to production. Specifications include exposing the MAX_RETRIES environment variable, labeled tier=queue, and also naming the container runner, and also with env var MAX_RETRIES assigned to false, and using openjdk:3.1 as its container image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""user-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""openjdk:3.1""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""queue""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""MAX_RETRIES""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""false""}]","apiVersion: v1

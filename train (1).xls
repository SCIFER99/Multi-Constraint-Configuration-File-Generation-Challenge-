        cpu: 1000m
        memory: 256Mi
    env:
    - name: SECRET_KEY
      value: '8080'",Pod,5
835,"We need a Pod named pdf-generator-pod in logging. The configuration requires tagged as team=platform, with centos:16 as the base image, additionally the container identified as main.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:16""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""main""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""platform""}]","apiVersion: v1

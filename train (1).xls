  cache_ttl: '300'
  log_level: warn
  workers: '2'",ConfigMap,3
1126,"We need a Service named worker-svc in default. The configuration requires set up as ClusterIP, operating on UDP, proxying to port 9000 on the backend, matching pods carrying app=config-server, and listening on port 8200.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""worker-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""config-server""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""9000""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""UDP""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8200""}]","apiVersion: v1

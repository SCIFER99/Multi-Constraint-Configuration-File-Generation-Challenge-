        cpu: '1'
        memory: 256Mi
  serviceAccountName: admin",Pod,8
1032,"Please configure a Service identified as notification-svc-svc within development. Make sure it has forwarding traffic to pods with app=cdn-origin, and of type LoadBalancer.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""notification-svc-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""cdn-origin""}]","apiVersion: v1

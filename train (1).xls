    protocol: TCP
  sessionAffinity: ClientIP",Service,4
563,"Configure the following Kubernetes resource: a Deployment with name ml-inference, deployed to logging. Specifications include scaled to 10 instances, pulling centos:14, additionally exposing container port 9092, running in a container named app, with RollingUpdate as the strategy type.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""ml-inference""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""centos:14""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""9092""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""RollingUpdate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: ml-inference
  namespace: logging
  labels:
    app: ml-inference
spec:
  replicas: 10
  selector:
    matchLabels:
      app: ml-inference
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: ml-inference
    spec:
      containers:
      - name: app
        image: centos:14
        ports:
        - containerPort: 9092
        imagePullPolicy: Always",Deployment,8
564,We need a Pod named report-gen-pod in staging. The configuration requires running logstash:5.0.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:5.0""}]","apiVersion: v1
kind: Pod
metadata:
  name: report-gen-pod
  namespace: staging
  labels:
    app: report-gen
    tier: queue
spec:
  restartPolicy: Always
  containers:
  - name: runner
    image: logstash:5.0
    env:
    - name: DATABASE_URL
      value: debug
  serviceAccountName: monitoring-sa",Pod,4
565,"Configure the following Kubernetes resource: an Ingress with name catalog-api-ingress, deployed to monitoring. Specifications include TLS-secured for app.example.com, responding to requests for app.example.com, including the rewrite-target=/ annotation, additionally with path matching set to Exact, and forwarding requests to the health-checker-svc service.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""catalog-api-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""app.example.com""}, {""path"": ""metadata.annotations.rewrite-target"", ""operator"": ""equals"", ""value"": ""/""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.name"", ""operator"": ""equals"", ""value"": ""health-checker-svc""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Exact""}, {""path"": ""spec.tls.0.hosts.0"", ""operator"": ""equals"", ""value"": ""app.example.com""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: catalog-api-ingress
  namespace: monitoring
  annotations:
    rewrite-target: /
spec:
  rules:
  - host: app.example.com
    http:
      paths:
      - path: /graphql
        pathType: Exact
        backend:
          service:
            name: health-checker-svc
            port:
              number: 8080
  tls:
  - hosts:
    - app.example.com
    secretName: catalog-api-tls",Ingress,8
566,Provision a ConfigMap called file-uploader-config in the monitoring namespace. This component is part of the Q3 platform migration project. This configuration supersedes the legacy setup that was decommissioned last quarter.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: file-uploader-config
  namespace: monitoring
data:
  feature_flags: dark_mode=false
  max_connections: '100'
  app_env: development
  database_url: mysql://db:3306/app
  cache_ttl: '3600'
  retry_count: '10'",ConfigMap,3
567,The cron-runner Deployment operates in the infra namespace. It has having 8 replicated pods. It features a memory request of 1Gi. It is configured with redis:2.0 as the base image. It is configured with naming the container server.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cron-runner""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""redis:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.template.spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""1Gi""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: cron-runner
  namespace: infra
  labels:
    app: cron-runner
    env: development
spec:
  replicas: 8
  selector:
    matchLabels:
      app: cron-runner
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: cron-runner
        env: development
    spec:
      containers:
      - name: server
        image: redis:2.0
        ports:
        - containerPort: 11211
        resources:
          requests:
            cpu: 250m
            memory: 1Gi
          limits:
            cpu: 750m
            memory: 64Mi
        env:
        - name: APP_NAME
          value: production",Deployment,7
568,"We need a ConfigMap named service-mesh-config in monitoring. The configuration requires having the log_level field, storing timeout_seconds with value 10, and also mapping app_name to metrics-collector, where the log_level entry includes war, where the log_level field is warn.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""service-mesh-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""data.log_level"", ""operator"": ""equals"", ""value"": ""warn""}, {""path"": ""data.log_level"", ""operator"": ""contains"", ""value"": ""war""}, {""path"": ""data.timeout_seconds"", ""operator"": ""equals"", ""value"": ""10""}, {""path"": ""data.app_name"", ""operator"": ""equals"", ""value"": ""metrics-collector""}, {""path"": ""data.log_level"", ""operator"": ""exists"", ""value"": """"}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: service-mesh-config
  namespace: monitoring
  labels:
    app: worker
data:
  timeout_seconds: '10'
  log_level: warn
  app_name: metrics-collector",ConfigMap,8
569,"Configure the following Kubernetes resource: a Service with name queue-worker-svc, deployed to development. Specifications include operating on TCP, routing to pods where app is session-store, and also set up as ClusterIP, tagged as tier=queue, and proxying to port 80 on the backend.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""queue-worker-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""queue""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""session-store""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""80""}]","apiVersion: v1
kind: Service
metadata:
  name: queue-worker-svc
  namespace: development
  labels:
    app: queue-worker
    tier: queue
spec:
  type: ClusterIP
  selector:
    app: session-store
  ports:
  - port: 3000
    targetPort: 80
    protocol: TCP",Service,8
570,The pdf-generator-pod Pod operates in the default namespace. It is configured with the container identified as server. It is configured with imagePullPolicy set to IfNotPresent. It features traefik:1.1 as its container image.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""traefik:1.1""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""IfNotPresent""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: v1
kind: Pod
metadata:
  name: pdf-generator-pod
  namespace: default
  labels:
    app: pdf-generator
    team: frontend
spec:
  restartPolicy: Always
  containers:
  - name: server
    image: traefik:1.1
    resources:
      requests:
        cpu: 200m
        memory: 2Gi
    imagePullPolicy: IfNotPresent",Pod,6
571,The metrics-collector-cron CronJob operates in the ml namespace. It is configured with set to fire at 0 */6 * * *. It includes based on the node:20 image. It includes failedJobsHistoryLimit set to 2. It features running in a container named job.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""metrics-collector-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 */6 * * *""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""node:20""}, {""path"": ""spec.failedJobsHistoryLimit"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""job""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: metrics-collector-cron
  namespace: ml
spec:
  schedule: 0 */6 * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: job
            image: node:20
            command:
            - /bin/sh
            - -c
            - echo hello
            resources:
              requests:
                cpu: 500m
                memory: 4Gi
          restartPolicy: OnFailure
  failedJobsHistoryLimit: 2",CronJob,7
572,Please configure an Ingress identified as gateway-ingress within development. Make sure it has routing requests to shop.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""gateway-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""shop.example.com""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: gateway-ingress
  namespace: development
  annotations:
    proxy-body-size: 50m
  labels:
    app: cache-proxy
spec:
  rules:
  - host: shop.example.com
    http:
      paths:
      - path: /uploads
        pathType: ImplementationSpecific
        backend:
          service:
            name: circuit-breaker-svc
            port:
              number: 443
  tls:
  - hosts:
    - shop.example.com
    secretName: gateway-tls",Ingress,4
573,"Please configure a ConfigMap identified as analytics-engine-config within platform. Feature flags controlling this service are managed through LaunchDarkly. Make sure it has where the redis_host field is redis://cache:6379/0, additionally carrying label env: production, and containing the cache_ttl entry.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""analytics-engine-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""data.cache_ttl"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.redis_host"", ""operator"": ""equals"", ""value"": ""redis://cache:6379/0""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: analytics-engine-config
  namespace: platform
  labels:
    env: production
data:
  api_key_prefix: sk-
  cache_ttl: '600'
  database_url: postgres://db:5432/app
  timeout_seconds: '5'
  redis_host: redis://cache:6379/0
  allowed_origins: https://example.com",ConfigMap,6
574,The web-app-cron CronJob operates in the development namespace. It requires the cron schedule 0 * * * *.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""web-app-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 * * * *""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: web-app-cron
  namespace: development
  labels:
    team: ml
spec:
  schedule: 0 * * * *
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: worker
            image: redis:21
            command:
            - /bin/sh
            - -c
            - echo hello
          restartPolicy: Never
  concurrencyPolicy: Forbid",CronJob,4
575,"Please configure a Deployment identified as auth-service within production. Feature flags controlling this service are managed through LaunchDarkly. Make sure it has 8 replicas, and also with Recreate as the strategy type, while also built from openjdk:2.0, configuring the CACHE_TTL variable, and also with its container called app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""auth-service""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""8""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""openjdk:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""CACHE_TTL""}, {""path"": ""spec.strategy.type"", ""operator"": ""equals"", ""value"": ""Recreate""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: auth-service
  namespace: production
  labels:
    app: auth-service
spec:
  replicas: 8
  selector:
    matchLabels:
      app: auth-service
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: auth-service
    spec:
      containers:
      - name: app
        image: openjdk:2.0
        ports:
        - containerPort: 1883
        resources:
          requests:
            cpu: 500m
            memory: 512Mi
          limits:
            cpu: 500m
            memory: 64Mi
        imagePullPolicy: Always
        env:
        - name: CACHE_TTL
          value: production",Deployment,8
576,"Spin up a Deployment called webhook-relay in the monitoring namespace. It should have the container should share the same name as the resource itself, scaled to 3 instances, with mongo:latest as the base image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""webhook-relay""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""3""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""mongo:latest""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""webhook-relay""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: webhook-relay
  namespace: monitoring
  labels:
    app: webhook-relay
spec:
  replicas: 3
  selector:
    matchLabels:
      app: webhook-relay
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: webhook-relay
    spec:
      containers:
      - name: webhook-relay
        image: mongo:latest
        ports:
        - containerPort: 6379
        imagePullPolicy: IfNotPresent
        env:
        - name: METRICS_PORT
          value: 'true'",Deployment,6
577,"Deploy a Deployment called model-trainer in the monitoring namespace. Ensure this configuration is reviewed by the security team before deployment. Capacity planning documents suggest this workload will double by end of year. It should have running 2 copies, while also whose container is called server, and running ubuntu:1.0.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""model-trainer""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""ubuntu:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: model-trainer
  namespace: monitoring
  labels:
    app: model-trainer
spec:
  replicas: 2
  selector:
    matchLabels:
      app: model-trainer
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: model-trainer
    spec:
      containers:
      - name: server
        image: ubuntu:1.0
        ports:
        - containerPort: 9000
        resources:
          requests:
            cpu: '2'
            memory: 256Mi
          limits:
            cpu: 750m
            memory: 512Mi
        env:
        - name: MAX_RETRIES
          value: production",Deployment,6
578,"Configure the following Kubernetes resource: an Ingress with name gateway-ingress, deployed to production. Specifications include directing traffic for the host ws.example.com, routing /admin requests.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""gateway-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""ws.example.com""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/admin""}]","apiVersion: networking.k8s.io/v1

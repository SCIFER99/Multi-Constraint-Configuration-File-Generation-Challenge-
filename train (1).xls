  cache_ttl: '600'",ConfigMap,6
156,"Configure the following Kubernetes resource: a ConfigMap with name file-uploader-config, deployed to ml.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}]","apiVersion: v1

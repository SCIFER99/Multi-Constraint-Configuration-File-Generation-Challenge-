          requests:
            cpu: '1'
            memory: 4Gi",Deployment,6
1120,"Set up a Service called analytics-engine-svc in the production namespace. It should have proxying to port 3000 on the backend, and also as a NodePort service.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""analytics-engine-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""3000""}]","apiVersion: v1

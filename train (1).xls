  serviceAccountName: admin",Pod,5
109,"We need a ConfigMap named cache-proxy-config in monitoring. The configuration requires app_name containing the text rep, and also storing feature_flags with value beta=true, while also including a feature_flags data key.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""data.feature_flags"", ""operator"": ""equals"", ""value"": ""beta=true""}, {""path"": ""data.feature_flags"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.app_name"", ""operator"": ""contains"", ""value"": ""rep""}]","apiVersion: v1

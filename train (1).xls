795,Please configure a Pod identified as email-sender-pod within default. Make sure it has logstash:16 as its container image.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""email-sender-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:16""}]","apiVersion: v1
kind: Pod

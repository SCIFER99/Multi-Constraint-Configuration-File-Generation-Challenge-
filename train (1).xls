  name: webhook-relay-pod
  namespace: development
  labels:
    app: webhook-relay
spec:
  restartPolicy: Always
  containers:
  - name: app
    image: postgres:8
    imagePullPolicy: Always",Pod,5
264,"Configure the following Kubernetes resource: a Deployment with name report-gen, deployed to default. Specifications include with its container called app, running 4 copies, built from kibana:4.0.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""report-gen""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""4""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""kibana:4.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1

            name: health-checker-svc
            port:
              number: 443
  tls:
  - hosts:
    - blog.example.com
    secretName: report-gen-tls",Ingress,4
384,"Configure the following Kubernetes resource: a Pod with name order-service-pod, deployed to default. Specifications include with the container labeled app, additionally pulling grafana/grafana:5.0, pulling images with policy Always, with service account default, with the app label set to order-service.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""order-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""grafana/grafana:5.0""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Always""}, {""path"": ""spec.serviceAccountName"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""order-service""}]","apiVersion: v1
kind: Pod
metadata:
  name: order-service-pod
  namespace: default
  labels:
    app: order-service
    tier: cache
spec:
  restartPolicy: OnFailure
  containers:
  - name: app
    image: grafana/grafana:5.0
    imagePullPolicy: Always
  serviceAccountName: default",Pod,8
385,"We need a Deployment named api-server in data. This service was originally implemented in the monolith and is now being extracted as a microservice. The configuration requires 5 replicas, with its container called api-server, based on the openjdk:3.0 image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""api-server""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""openjdk:3.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""api-server""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: data
  labels:
    app: api-server
    team: infra
    release: stable
    version: v1
spec:
  replicas: 5
  selector:
    matchLabels:
      app: api-server
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: api-server
        team: infra
        release: stable
        version: v1
    spec:
      containers:
      - name: api-server
        image: openjdk:3.0
        ports:
        - containerPort: 4222
        resources:
          requests:
            cpu: 50m
            memory: 1Gi
        imagePullPolicy: Always",Deployment,6
386,"Provision a ConfigMap called order-service-config in the default namespace. It should have having app_env=production in its data, with the app_name value including log, while also with allowed_origins configured as https://app.example.com, and with allowed_origins containing the text htt.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""order-service-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""data.allowed_origins"", ""operator"": ""equals"", ""value"": ""https://app.example.com""}, {""path"": ""data.app_env"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""data.allowed_origins"", ""operator"": ""contains"", ""value"": ""htt""}, {""path"": ""data.app_name"", ""operator"": ""contains"", ""value"": ""log""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: order-service-config
  namespace: default
data:
  allowed_origins: https://app.example.com
  app_env: production
  database_url: postgres://db:5432/app
  app_name: log-aggregator
  max_connections: '100'",ConfigMap,7
387,"Set up a Deployment called dns-resolver in the production namespace. It should have serving on container port 8080, with node:2.0 as the base image, annotated with version=v2.1, and also having 2 replicated pods, with the container labeled app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""node:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""8080""}, {""path"": ""metadata.labels.version"", ""operator"": ""equals"", ""value"": ""v2.1""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: dns-resolver
  namespace: production
  labels:
    app: dns-resolver
    version: v2.1
spec:
  replicas: 2
  selector:
    matchLabels:
      app: dns-resolver
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: dns-resolver
        version: v2.1
    spec:
      containers:
      - name: app
        image: node:2.0
        ports:
        - containerPort: 8080",Deployment,8
388,Provision an Ingress called rate-limiter-ingress in the production namespace. It should have directing traffic for the host shop.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""shop.example.com""}]","apiVersion: networking.k8s.io/v1

        ports:
        - containerPort: 3000
        imagePullPolicy: Always",Deployment,7
896,"Configure the following Kubernetes resource: a Pod with name metrics-collector-pod, deployed to infra. Specifications include with minio/minio:stable as the base image, including REDIS_URL in its environment, with REDIS_URL configured as debug, while also with the team label set to platform, while also with the app label set to metrics-collector.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""metrics-collector-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""minio/minio:stable""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""debug""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""REDIS_URL""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""metrics-collector""}]","apiVersion: v1
kind: Pod
metadata:
  name: metrics-collector-pod
  namespace: infra
  labels:
    app: metrics-collector
    team: platform
spec:
  restartPolicy: OnFailure
  containers:
  - name: server
    image: minio/minio:stable
    env:
    - name: REDIS_URL
      value: debug",Pod,8
897,"Please configure a Service identified as stream-consumer-svc within infra. Make sure it has communicating over TCP, and also proxying to port 9000 on the backend, with the tier label set to database, and of type ClusterIP.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""TCP""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""database""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""9000""}]","apiVersion: v1
kind: Service
metadata:
  name: stream-consumer-svc
  namespace: infra
  labels:
    app: stream-consumer
    tier: database
spec:
  type: ClusterIP
  selector:
    app: service-mesh
  ports:
  - port: 8443
    targetPort: 9000
    protocol: TCP",Service,7
898,The stream-consumer-ingress Ingress operates in the production namespace. It features handling traffic for admin.example.com. It includes having the annotation rewrite-target configured to Ingress.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""admin.example.com""}, {""path"": ""metadata.annotations.rewrite-target"", ""operator"": ""equals"", ""value"": ""Ingress for stream-consumer-ingress""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: stream-consumer-ingress
  namespace: production
  annotations:
    rewrite-target: Ingress for stream-consumer-ingress
  labels:
    env: production
spec:
  rules:
  - host: admin.example.com
    http:
      paths:
      - path: /api/v2
        pathType: ImplementationSpecific
        backend:
          service:
            name: proxy-server-svc
            port:
              number: 8080
  ingressClassName: haproxy",Ingress,5
899,"Configure the following Kubernetes resource: a Service with name cache-proxy-svc, deployed to infra. This was previously hosted on AWS ECS before the Kubernetes migration. Specifications include as a NodePort service.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cache-proxy-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}]","apiVersion: v1
kind: Service
metadata:
  name: cache-proxy-svc
  namespace: infra
  labels:
    app: cache-proxy
    tier: backend
spec:
  type: NodePort
  selector:
    app: web-app
  ports:
  - port: 5432
    targetPort: 8200
    protocol: UDP
    nodePort: 31333
  sessionAffinity: ClientIP",Service,4
900,"Provision a Deployment called dns-resolver in the default namespace. It should have 2 replicas, while also with a memory request of 128Mi, and also using alpine:slim as its container image, opening container port 1883, running in a container named app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""alpine:slim""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}, {""path"": ""spec.template.spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""128Mi""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""1883""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: dns-resolver
  namespace: default
  labels:
    app: dns-resolver
spec:
  replicas: 2
  selector:
    matchLabels:
      app: dns-resolver
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: dns-resolver
    spec:
      containers:
      - name: app
        image: alpine:slim
        ports:
        - containerPort: 1883
        resources:
          requests:
            cpu: '1'
            memory: 128Mi
        imagePullPolicy: Never",Deployment,8
901,"We need an Ingress named rate-limiter-ingress in production. Capacity planning documents suggest this workload will double by end of year. The configuration requires the app label set to cdn-origin, and directing traffic for the host auth.example.com.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""auth.example.com""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""cdn-origin""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: rate-limiter-ingress
  namespace: production
  labels:
    app: cdn-origin
spec:
  rules:
  - host: auth.example.com
    http:
      paths:
      - path: /static
        pathType: Exact
        backend:
          service:
            name: cdn-origin-svc
            port:
              number: 80
  tls:
  - hosts:
    - auth.example.com
    secretName: rate-limiter-tls",Ingress,5
902,"Configure the following Kubernetes resource: a ConfigMap with name config-server-config, deployed to infra. This component is part of the Q3 platform migration project. Specifications include with the debug_mode value including tru, and also having app_name=auth-service in its data, while also with a workers entry present, additionally storing debug_mode with value true.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""config-server-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""data.workers"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.debug_mode"", ""operator"": ""equals"", ""value"": ""true""}, {""path"": ""data.debug_mode"", ""operator"": ""contains"", ""value"": ""tru""}, {""path"": ""data.app_name"", ""operator"": ""equals"", ""value"": ""auth-service""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: config-server-config
  namespace: infra
  labels:
    app: event-bus
data:
  workers: '4'
  app_name: auth-service
  app_env: production
  debug_mode: 'true'",ConfigMap,7
903,The api-server Deployment operates in the platform namespace. It features the container labeled app. It features scaled to 2 instances. It is configured with running traefik:1.2.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""api-server""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""traefik:1.2""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""app""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-server
  namespace: platform
  labels:
    app: api-server
    env: production
    team: frontend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: api-server
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: api-server
        env: production
        team: frontend
    spec:
      containers:
      - name: app
        image: traefik:1.2
        ports:
        - containerPort: 11211
        resources:
          requests:
            cpu: 1000m
            memory: 4Gi
          limits:
            cpu: 250m
            memory: 64Mi
        env:
        - name: METRICS_PORT
          value: '8080'",Deployment,6
904,"Configure the following Kubernetes resource: a ConfigMap with name config-server-config, deployed to default. Capacity planning documents suggest this workload will double by end of year. This service was originally implemented in the monolith and is now being extracted as a microservice. Specifications include containing the redis_host entry, and which includes a timeout_seconds key.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""config-server-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""data.timeout_seconds"", ""operator"": ""exists"", ""value"": """"}, {""path"": ""data.redis_host"", ""operator"": ""exists"", ""value"": """"}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: config-server-config
  namespace: default
  labels:
    team: devops
data:
  timeout_seconds: '120'
  redis_host: redis://cache:6379/0",ConfigMap,5
905,"Configure a Service called payment-gateway-svc in the platform namespace. It should have labeled tier=frontend, of type LoadBalancer, and with port 9092 open.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""payment-gateway-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""LoadBalancer""}, {""path"": ""metadata.labels.tier"", ""operator"": ""equals"", ""value"": ""frontend""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""9092""}]","apiVersion: v1
kind: Service
metadata:
  name: payment-gateway-svc
  namespace: platform
  labels:
    app: payment-gateway
    tier: frontend
spec:
  type: LoadBalancer
  selector:
    app: gateway
  ports:
  - port: 9092
    targetPort: 15672
    protocol: TCP",Service,6
906,"Spin up a Deployment called batch-processor in the staging namespace. Related services include the auth-proxy and rate-limiter deployments in the same namespace. It should have pulling images with policy IfNotPresent, with its container called worker, and also built from golang:20, and having 3 replicated pods.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""3""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""golang:20""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""IfNotPresent""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: batch-processor
  namespace: staging
  labels:
    app: batch-processor
    version: v2.0
    env: staging
    team: platform
spec:
  replicas: 3
  selector:
    matchLabels:
      app: batch-processor
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: batch-processor
        version: v2.0
        env: staging
        team: platform
    spec:
      containers:
      - name: worker
        image: golang:20
        ports:
        - containerPort: 9000
        resources:
          requests:
            cpu: 1000m
            memory: 2Gi
          limits:
            cpu: '1'
            memory: 64Mi
        imagePullPolicy: IfNotPresent
        env:
        - name: JWT_SECRET
          value: info",Deployment,7
907,"Configure the following Kubernetes resource: a ConfigMap with name batch-processor-config, deployed to ml. Specifications include tagged as team=infra, additionally with app_env containing the text pro, with workers configured as 4, and also with rate_limit containing the text 500, containing database_url set to mysql://db:3306/app.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""batch-processor-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""data.app_env"", ""operator"": ""contains"", ""value"": ""pro""}, {""path"": ""data.database_url"", ""operator"": ""equals"", ""value"": ""mysql://db:3306/app""}, {""path"": ""metadata.labels.team"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""data.rate_limit"", ""operator"": ""contains"", ""value"": ""500""}, {""path"": ""data.workers"", ""operator"": ""equals"", ""value"": ""4""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: batch-processor-config
  namespace: ml
  labels:
    team: infra
data:
  app_env: production
  api_key_prefix: pk-
  redis_host: redis://cache:6379/0
  workers: '4'
  rate_limit: '5000'
  database_url: mysql://db:3306/app",ConfigMap,8
908,"We need a CronJob named health-checker-cron in platform. This service was originally implemented in the monolith and is now being extracted as a microservice. Ensure this configuration is reviewed by the security team before deployment. The configuration requires the cron schedule 0 0 * * 0, based on the logstash:3.0 image, restarting on Never.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""CronJob""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""health-checker-cron""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.schedule"", ""operator"": ""equals"", ""value"": ""0 0 * * 0""}, {""path"": ""spec.jobTemplate.spec.template.spec.restartPolicy"", ""operator"": ""equals"", ""value"": ""Never""}, {""path"": ""spec.jobTemplate.spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""logstash:3.0""}]","apiVersion: batch/v1
kind: CronJob
metadata:
  name: health-checker-cron
  namespace: platform
spec:
  schedule: 0 0 * * 0
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: task
            image: logstash:3.0
            command:
            - /bin/sh
            - -c
            - cleanup.sh
          restartPolicy: Never",CronJob,6
909,"We need an Ingress named frontend-ingress in default. Performance benchmarks show this configuration handles 500 concurrent connections comfortably. Documentation for this component is maintained in the team wiki under infrastructure/configs. The configuration requires directing traffic for the host auth.example.com, and carrying annotation proxy-body-size: Ingress.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""frontend-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""default""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""auth.example.com""}, {""path"": ""metadata.annotations.proxy-body-size"", ""operator"": ""equals"", ""value"": ""Ingress for frontend-ingress""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: default
  annotations:
    proxy-body-size: Ingress for frontend-ingress
  labels:
    env: testing
spec:
  rules:
  - host: auth.example.com
    http:
      paths:
      - path: /graphql
        pathType: Exact
        backend:
          service:
            name: service-mesh-svc
            port:
              number: 80",Ingress,5
910,Deploy a ConfigMap called rate-limiter-config in the development namespace.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: rate-limiter-config
  namespace: development
data:
  database_url: mysql://db:3306/app
  cache_ttl: '60'
  app_port: '8080'
  max_connections: '100'
  feature_flags: enable_v2=true
  api_key_prefix: api-",ConfigMap,3
911,The health-checker-svc Service operates in the ml namespace. It requires as a NodePort service.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""health-checker-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}]","apiVersion: v1
kind: Service
metadata:
  name: health-checker-svc
  namespace: ml
spec:
  type: NodePort
  selector:
    app: image-processor
  ports:
  - port: 443
    targetPort: 1883
    protocol: UDP
    nodePort: 32485
  sessionAffinity: ClientIP",Service,4
912,The load-balancer-svc Service operates in the logging namespace. It is configured with of type ClusterIP. It is configured with forwarding traffic to pods with app=data-pipeline. The associated monitoring dashboard is available on Grafana. Cost allocation for this resource falls under the platform-infrastructure budget category. It includes accepting traffic on port 27017.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""load-balancer-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""logging""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""data-pipeline""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""27017""}]","apiVersion: v1
kind: Service
metadata:
  name: load-balancer-svc
  namespace: logging
spec:
  type: ClusterIP
  selector:
    app: data-pipeline
  ports:
  - port: 27017
    targetPort: 8443
    protocol: UDP",Service,6
913,The auth-service-ingress Ingress operates in the production namespace. It is configured with handling the /docs endpoint. It includes routing to backend service webhook-relay-svc. It requires serving ws.example.com. It requires port 80 open.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""auth-service-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""ws.example.com""}, {""path"": ""spec.rules.0.http.paths.0.path"", ""operator"": ""equals"", ""value"": ""/docs""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.name"", ""operator"": ""equals"", ""value"": ""webhook-relay-svc""}, {""path"": ""spec.rules.0.http.paths.0.backend.service.port.number"", ""operator"": ""equals"", ""value"": ""80""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: auth-service-ingress
  namespace: production
  annotations:
    ssl-redirect: 50m
spec:
  rules:
  - host: ws.example.com
    http:
      paths:
      - path: /docs
        pathType: ImplementationSpecific
        backend:
          service:
            name: webhook-relay-svc
            port:
              number: 80",Ingress,7
914,"Please configure a Deployment identified as circuit-breaker within production. Make sure it has running kibana:3.9, and also the container identified as worker, needing 200m of CPU, additionally running 5 copies, with imagePullPolicy set to Always.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""5""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""kibana:3.9""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Always""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""200m""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: circuit-breaker
  namespace: production
  labels:
    app: circuit-breaker
spec:
  replicas: 5
  selector:
    matchLabels:
      app: circuit-breaker
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: circuit-breaker
    spec:
      containers:
      - name: worker
        image: kibana:3.9
        ports:
        - containerPort: 5432
        resources:
          requests:
            cpu: 200m
            memory: 256Mi
        imagePullPolicy: Always",Deployment,8
915,"We need a Pod named notification-svc-pod in platform. Expected traffic volume is approximately 10,000 requests per second during peak hours. The configuration requires TIMEOUT defined in its environment, running in a container named runner, and also with traefik:3.9 as the base image, and pulling images with policy IfNotPresent.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""notification-svc-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""platform""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""traefik:3.9""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""IfNotPresent""}, {""path"": ""spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""runner""}, {""path"": ""spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""TIMEOUT""}]","apiVersion: v1
kind: Pod
metadata:
  name: notification-svc-pod
  namespace: platform
  labels:
    app: notification-svc
spec:
  restartPolicy: Always
  containers:
  - name: runner
    image: traefik:3.9
    env:
    - name: TIMEOUT
      value: 'true'
    imagePullPolicy: IfNotPresent",Pod,7
916,"We need a ConfigMap named file-uploader-config in monitoring. The team responsible for this resource can be reached via the platform-ops Slack channel. Note that this resource may be scaled horizontally during high-traffic events. The configuration requires where the api_key_prefix field is pk-, mapping max_connections to 200, and having feature_flags=enable_v2=true in its data.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""ConfigMap""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""file-uploader-config""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""data.max_connections"", ""operator"": ""equals"", ""value"": ""200""}, {""path"": ""data.api_key_prefix"", ""operator"": ""equals"", ""value"": ""pk-""}, {""path"": ""data.feature_flags"", ""operator"": ""equals"", ""value"": ""enable_v2=true""}]","apiVersion: v1
kind: ConfigMap
metadata:
  name: file-uploader-config
  namespace: monitoring
  labels:
    team: ml
data:
  max_connections: '200'
  api_key_prefix: pk-
  cache_ttl: '600'
  feature_flags: enable_v2=true
  workers: '4'",ConfigMap,6
917,"We need a Deployment named rate-limiter in data. Ensure this configuration is reviewed by the security team before deployment. Expected traffic volume is approximately 10,000 requests per second during peak hours. The configuration requires built from alpine:3.9, having REDIS_URL set to info, having 1 replicated pods, with its container called server, declaring the REDIS_URL env var.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""rate-limiter""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""alpine:3.9""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""server""}, {""path"": ""spec.template.spec.containers.0.env.0.name"", ""operator"": ""equals"", ""value"": ""REDIS_URL""}, {""path"": ""spec.template.spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""info""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: rate-limiter
  namespace: data
  labels:
    app: rate-limiter
    tier: database
    team: devops
spec:
  replicas: 1
  selector:
    matchLabels:
      app: rate-limiter
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: rate-limiter
        tier: database
        team: devops
    spec:
      containers:
      - name: server
        image: alpine:3.9
        ports:
        - containerPort: 8200
        resources:
          requests:
            cpu: 500m
            memory: 512Mi
          limits:
            cpu: '1'
            memory: 128Mi
        imagePullPolicy: Always
        env:
        - name: REDIS_URL
          value: info",Deployment,8
918,"We need a Deployment named data-pipeline in monitoring. The configuration requires the container should share the same name as the resource itself, additionally maintaining 2 pods, and using postgres:1.2 as its container image.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""data-pipeline""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""postgres:1.2""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""data-pipeline""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: data-pipeline
  namespace: monitoring
  labels:
    app: data-pipeline
spec:
  replicas: 2
  selector:
    matchLabels:
      app: data-pipeline
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: data-pipeline
    spec:
      containers:
      - name: data-pipeline
        image: postgres:1.2
        ports:
        - containerPort: 15672
        resources:
          requests:
            cpu: 200m
            memory: 4Gi
          limits:
            cpu: 1000m
            memory: 1Gi
        env:
        - name: MAX_RETRIES
          value: production",Deployment,6
919,The circuit-breaker-ingress Ingress operates in the data namespace. It is configured with bearing the label app=batch-processor. It is configured with a Exact pathType. It is configured with responding to requests for status.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""circuit-breaker-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""status.example.com""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""batch-processor""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""Exact""}]","apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: circuit-breaker-ingress
  namespace: data
  annotations:
    proxy-body-size: 'true'
  labels:
    app: batch-processor
spec:
  rules:
  - host: status.example.com
    http:
      paths:
      - path: /api/v2
        pathType: Exact
        backend:
          service:
            name: data-pipeline-svc
            port:
              number: 8080",Ingress,6
920,Deploy an Ingress called stream-consumer-ingress in the data namespace. Cost allocation for this resource falls under the platform-infrastructure budget category. It should have serving ws.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""ws.example.com""}]","apiVersion: networking.k8s.io/v1

  name: cron-runner
  namespace: infra
  labels:
    app: cron-runner
    release: blue
    tier: database
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cron-runner
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: cron-runner
        release: blue

    env: testing
spec:
  type: LoadBalancer
  selector:
    app: search-engine
  ports:
  - port: 9090
    targetPort: 11211
    protocol: UDP
  sessionAffinity: ClientIP",Service,8
504,"Configure the following Kubernetes resource: a Pod with name analytics-engine-pod, deployed to infra. Specifications include with python:2.0 as the base image, allocated 2Gi memory, carrying the app=analytics-engine label, and also accessible via port 3306, and using Always image pull policy.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""analytics-engine-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""python:2.0""}, {""path"": ""spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""3306""}, {""path"": ""spec.containers.0.imagePullPolicy"", ""operator"": ""equals"", ""value"": ""Always""}, {""path"": ""spec.containers.0.resources.requests.memory"", ""operator"": ""equals"", ""value"": ""2Gi""}, {""path"": ""metadata.labels.app"", ""operator"": ""equals"", ""value"": ""analytics-engine""}]","apiVersion: v1

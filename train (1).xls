    imagePullPolicy: IfNotPresent
  serviceAccountName: monitoring-sa",Pod,8
668,The pdf-generator-svc Service operates in the production namespace. It requires operating as a ClusterIP service. It is configured with routing to pods where app is catalog-api.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""catalog-api""}]","apiVersion: v1

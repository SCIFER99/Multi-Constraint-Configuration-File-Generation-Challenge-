1079,"We need a Deployment named stream-consumer in data. The configuration requires running rabbitmq:2.0, with a CPU request of 1, while also maintaining 2 pods, and with its container called stream-consumer.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""stream-consumer""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""data""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""2""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""rabbitmq:2.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""stream-consumer""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""1""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: stream-consumer
  namespace: data
  labels:
    app: stream-consumer
    team: platform
spec:
  replicas: 2
  selector:
    matchLabels:
      app: stream-consumer
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: stream-consumer
        team: platform
    spec:
      containers:
      - name: stream-consumer
        image: rabbitmq:2.0
        ports:
        - containerPort: 4222
        resources:
          requests:
            cpu: '1'
            memory: 4Gi
          limits:
            cpu: '2'
            memory: 512Mi
        imagePullPolicy: Never",Deployment,7

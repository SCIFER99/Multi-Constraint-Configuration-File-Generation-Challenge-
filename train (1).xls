            name: log-aggregator-svc
            port:
              number: 3000",Ingress,8
432,"We need a Pod named auth-service-pod in staging. The configuration requires ubuntu:21 as its container image, and with env var NODE_ENV assigned to false.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""auth-service-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""ubuntu:21""}, {""path"": ""spec.containers.0.env.0.value"", ""operator"": ""equals"", ""value"": ""false""}]","apiVersion: v1
kind: Pod
metadata:
  name: auth-service-pod
  namespace: staging
  labels:
    app: auth-service
spec:
  restartPolicy: Never
  containers:
  - name: worker
    image: ubuntu:21
    ports:
    - containerPort: 8500
    resources:
      requests:
        cpu: 500m
        memory: 4Gi
    env:
    - name: NODE_ENV
      value: 'false'
    imagePullPolicy: Always",Pod,5
433,"Please configure a Service identified as pdf-generator-svc within monitoring. Make sure it has port 8500 open, while also annotated with env=production, set up as ClusterIP.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""pdf-generator-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""monitoring""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8500""}, {""path"": ""metadata.labels.env"", ""operator"": ""equals"", ""value"": ""production""}]","apiVersion: v1

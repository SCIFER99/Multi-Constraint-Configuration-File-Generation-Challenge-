827,"Create a Deployment called dns-resolver in the staging namespace. It should have running ubuntu:1.0, running in a container named worker, allocated 1 CPU, and also with 1 replicas, and serving on container port 9000.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Deployment""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""dns-resolver""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""staging""}, {""path"": ""spec.replicas"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""ubuntu:1.0""}, {""path"": ""spec.template.spec.containers.0.name"", ""operator"": ""equals"", ""value"": ""worker""}, {""path"": ""spec.template.spec.containers.0.resources.requests.cpu"", ""operator"": ""equals"", ""value"": ""1""}, {""path"": ""spec.template.spec.containers.0.ports.0.containerPort"", ""operator"": ""equals"", ""value"": ""9000""}]","apiVersion: apps/v1
kind: Deployment
metadata:
  name: dns-resolver
  namespace: staging
  labels:
    app: dns-resolver
spec:
  replicas: 1
  selector:
    matchLabels:
      app: dns-resolver
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: dns-resolver
    spec:

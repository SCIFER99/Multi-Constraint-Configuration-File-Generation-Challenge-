        env:
        - name: DATABASE_URL
          value: info",Deployment,7
324,"We need a Service named cron-runner-svc in infra. The data processed by this service is classified as PII and must comply with GDPR requirements. The team responsible for this resource can be reached via the platform-ops Slack channel. The configuration requires forwarding traffic to pods with app=auth-service, using UDP protocol, listening on port 8080, as a ClusterIP service, and also targeting port 8200.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""cron-runner-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""infra""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""ClusterIP""}, {""path"": ""spec.selector.app"", ""operator"": ""equals"", ""value"": ""auth-service""}, {""path"": ""spec.ports.0.port"", ""operator"": ""equals"", ""value"": ""8080""}, {""path"": ""spec.ports.0.targetPort"", ""operator"": ""equals"", ""value"": ""8200""}, {""path"": ""spec.ports.0.protocol"", ""operator"": ""equals"", ""value"": ""UDP""}]","apiVersion: v1
kind: Service
metadata:
  name: cron-runner-svc
  namespace: infra
spec:
  type: ClusterIP
  selector:
    app: auth-service
  ports:
  - port: 8080
    targetPort: 8200
    protocol: UDP",Service,8
325,The service-mesh-pod Pod operates in the development namespace. It has pulling alpine:1.1.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Pod""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""service-mesh-pod""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.containers.0.image"", ""operator"": ""equals"", ""value"": ""alpine:1.1""}]","apiVersion: v1
kind: Pod
metadata:
  name: service-mesh-pod
  namespace: development
  labels:
    app: service-mesh
spec:
  restartPolicy: Never
  containers:
  - name: worker
    image: alpine:1.1
    ports:
    - containerPort: 9000

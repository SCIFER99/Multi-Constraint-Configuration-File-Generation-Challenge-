      requests:
        cpu: '1'
        memory: 256Mi
    env:
    - name: CACHE_TTL
      value: '8080'",Pod,7
208,Please configure a Service identified as load-balancer-svc within development. Make sure it has as a NodePort service.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Service""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""load-balancer-svc""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""development""}, {""path"": ""spec.type"", ""operator"": ""equals"", ""value"": ""NodePort""}]","apiVersion: v1

  name: user-service-svc
  namespace: development
spec:
  type: LoadBalancer
  selector:
    app: data-pipeline
  ports:
  - port: 8200
    targetPort: 8500
    protocol: TCP",Service,8
1035,"Deploy an Ingress called search-engine-ingress in the production namespace. It should have employing ImplementationSpecific path matching, bound to host auth.example.com, and with the rewrite-target annotation as 50m.","[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""search-engine-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""production""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""auth.example.com""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""ImplementationSpecific""}, {""path"": ""metadata.annotations.rewrite-target"", ""operator"": ""equals"", ""value"": ""50m""}]","apiVersion: networking.k8s.io/v1

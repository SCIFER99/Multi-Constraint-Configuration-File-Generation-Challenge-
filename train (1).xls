          containers:
          - name: worker
            image: vault:1.2
          restartPolicy: Never",CronJob,8
1008,The queue-worker-ingress Ingress operates in the ml namespace. It has pathType ImplementationSpecific. It features serving grafana.example.com.,"[{""path"": ""kind"", ""operator"": ""equals"", ""value"": ""Ingress""}, {""path"": ""metadata.name"", ""operator"": ""equals"", ""value"": ""queue-worker-ingress""}, {""path"": ""metadata.namespace"", ""operator"": ""equals"", ""value"": ""ml""}, {""path"": ""spec.rules.0.host"", ""operator"": ""equals"", ""value"": ""grafana.example.com""}, {""path"": ""spec.rules.0.http.paths.0.pathType"", ""operator"": ""equals"", ""value"": ""ImplementationSpecific""}]","apiVersion: networking.k8s.io/v1
